{
  "name": "andrew-dryga-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Astro 6 site for dryga.com with Tailwind, MDX, Sitemap, and Image.",
  "engines": {
    "node": ">=18.14.1"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "smoke:component-library": "node scripts/smoke-component-library.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/sitemap": "^3.7.1",
    "@shikijs/twoslash": "^4.0.2",
    "astro": "^6.0.1",
    "mixpanel-browser": "^2.50.0",
    "sharp": "^0.34.5"
  },
  "overrides": {
    "@astrojs/check": {
      "lodash": ">=4.17.21"
    }
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^25.4.0",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "typescript-eslint": "^8.57.0",
    "postcss": "^8.5.6",
    "prettier": "^3.3.0",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.0.0"
  }
}

{
  "name": "andrew-dryga-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Astro 4 site for dryga.com (side-by-side scaffold) with Tailwind, React islands, MDX, Sitemap, and Image.",
  "engines": {
    "node": ">=18.14.1"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx,.astro",
    "format": "prettier --write .",
    "smoke:component-library": "node scripts/smoke-component-library.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^3.0.0",
    "@astrojs/sitemap": "^3.0.0",
    "@astrojs/tailwind": "^5.0.0",
    "@shikijs/twoslash": "^3.13.0",
    "astro": "^4.0.0",
    "mixpanel-browser": "^2.50.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.0.0",
    "eslint-plugin-astro": "^1.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.3.0",
    "prettier-plugin-astro": "^0.14.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.0.0"
  }
}

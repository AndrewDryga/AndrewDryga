{
  "name": "andrew-dryga-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Astro 6 site for dryga.com with Tailwind, MDX, Sitemap, and Image.",
  "engines": {
    "node": ">=18.14.1"
  },
  "scripts": {
    "predev": "LLMS_BUILD_IF_MISSING=true LLMS_EXPORT_TARGETS=public/llms-full.txt node scripts/generate-llms-full.mjs .llms-cache",
    "dev": "astro dev",
    "build": "astro build && LLMS_FORCE_REBUILD=true node scripts/generate-llms-full.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "smoke:component-library": "node scripts/smoke-component-library.mjs",
    "generate:llms-full": "node scripts/generate-llms-full.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/sitemap": "^3.7.1",
    "@shikijs/twoslash": "^4.0.2",
    "astro": "^6.0.1",
    "astro-critters": "^2.2.1",
    "sharp": "^0.34.5"
  },
  "overrides": {
    "@astrojs/check": {
      "lodash": ">=4.17.21",
      "yaml-language-server": "^1.21.0"
    },
    "volar-service-yaml": {
      "yaml-language-server": "^1.21.0"
    },
    "yaml-language-server": {
      "yaml": "2.8.3"
    },
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^25.4.0",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "html-to-text": "^9.0.5",
    "postcss": "^8.5.6",
    "prettier": "^3.3.0",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.0"
  }
}

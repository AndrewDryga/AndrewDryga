---
import BaseLayout from "@/components/BaseLayout.astro";
import Header from "@/components/Header.astro";
import ComponentLibraryNav from "@/components/ComponentLibraryNav.astro";
import {
  SequenceDiagram,
  Participants,
  Participant,
  Messages,
  Message,
  Note,
  SelfCall,
  ActivationBox,
  CombinedFragment,
  CombinedOperand,
} from "@/components/mdx/SequenceDiagram";
import AsciiStackedBar from "@/components/ascii/StackedBar.astro";
import AsciiVerticalBar from "@/components/ascii/VerticalBar.astro";

if (import.meta.env.PROD) {
  return Astro.redirect("/");
}

const site = Astro.site ?? new URL("https://dryga.com/");
const canonical = new URL("/component-library/charts/", site).toString();

const pieSegments = [
  { label: "Build", color: "text-terminal-cyan", value: 34 },
  { label: "QA", color: "text-terminal-green", value: 26 },
  { label: "Deploy", color: "text-terminal-yellow", value: 22 },
  { label: "Ops", color: "text-muted-foreground", value: 18 },
];

const sparklinePoints = [8, 11, 7, 13, 15, 12, 18, 20, 17, 23];

const barSeries = [
  { label: "Mon", value: 6, color: "text-terminal-cyan" },
  { label: "Tue", value: 9, color: "text-terminal-green" },
  { label: "Wed", value: 4, color: "text-terminal-yellow" },
  { label: "Thu", value: 11, color: "text-primary" },
  { label: "Fri", value: 7, color: "text-muted-foreground" },
];

function buildSparkline(points: number[]) {
  const glyphs = ["▁", "▂", "▃", "▅", "▆", "▇", "█"];
  const min = Math.min(...points);
  const max = Math.max(...points);
  return points
    .map((value) => {
      if (max === min) return glyphs[0];
      const normalized = (value - min) / (max - min);
      const index = Math.min(
        glyphs.length - 1,
        Math.floor(normalized * glyphs.length),
      );
      return glyphs[index];
    })
    .join("");
}

const sparkline = buildSparkline(sparklinePoints);
---

<BaseLayout
  title="Component Library — Charts & Flows"
  description="Terminal-native charts, ASCII spark lines, vertical bars, and flow diagrams."
  canonical={canonical}
  noIndex
>
  <Header slot="header" />

  <section class="px-4 py-12 md:py-16">
    <div class="mx-auto flex max-w-6xl flex-col gap-10">
      <ComponentLibraryNav current="charts" />

      <header class="space-y-3">
        <p class="font-mono text-sm text-terminal-green">$ viz charts</p>
        <h1 class="text-4xl md:text-5xl font-bold text-foreground">
          Charts &amp; flows
        </h1>
        <p class="max-w-3xl text-sm text-muted-foreground">
          Compose dashboard-friendly visuals without leaving the terminal
          aesthetic — ASCII pies, spark lines, vertical bars, and annotated
          flows.
        </p>
      </header>

      <div class="space-y-16">
        <section id="stacked" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">
              ASCII stacked bar
            </h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              Horizontal resource split rendered as a single stacked bar so
              proportions stay legible in monospace terminals.
            </p>
          </header>

          <div class="rounded-lg border border-border bg-card p-6">
            <AsciiStackedBar segments={pieSegments} width={32} />
            <p class="mt-6 font-mono text-xs text-muted-foreground">
              Each block represents roughly 3% of the weekly pipeline — tweak
              the weights to match your own mix.
            </p>
          </div>
        </section>

        <section id="sparkline" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">Spark line trend</h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              A week of deployment throughput presented as a single line of
              unicode characters.
            </p>
          </header>

          <div class="rounded-lg border border-border bg-card p-6 font-mono">
            <div class="flex flex-wrap items-baseline gap-3">
              <span class="text-terminal-cyan text-lg tracking-[0.3em]">
                {sparkline}
              </span>
              <span class="text-xs text-muted-foreground">
                min {Math.min(...sparklinePoints)} / max {
                  Math.max(...sparklinePoints)
                }
              </span>
            </div>
            <p class="mt-4 text-xs text-muted-foreground">
              Use the glyph set `▁▂▃▄▅▆▇█` and normalise incoming metrics to map
              values to characters.
            </p>
          </div>
        </section>

        <section id="bars" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">
              ASCII vertical bars
            </h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              Deployment throughput rendered as stacked glyphs — five columns,
              left aligned, no filler.
            </p>
          </header>

          <div class="rounded-lg border border-border bg-card p-6">
            <AsciiVerticalBar bars={barSeries} maxHeight={9} />
            <p class="mt-4 font-mono text-xs text-muted-foreground">
              Each block equals roughly one release per day — tweak <code
                >maxHeight</code
              > to match your scale.
            </p>
          </div>
        </section>

        <section id="flow" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">Deployment flow</h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              Text-only process diagram inspired by the linked example, complete
              with branch annotations.
            </p>
          </header>

          <div
            class="rounded-lg border border-border bg-card p-6 font-mono text-sm leading-relaxed"
          >
            <pre
              role="img"
              aria-label="Deployment flow diagram showing stage build, quality gate, deploy, rollback path, and observe metrics"
              class="whitespace-pre text-terminal-cyan overflow-x-auto">
┌─────────────┐    ┌──────────────┐    ┌────────────┐
│ Stage build │───▶│ Quality gate │───▶│   Deploy   │
│    ci/cd    │    │    checks    │    │   fly.io   │
└─────────────┘    └──────────────┘    └────────────┘
         │                 │                  │
         │                 ▼                  │
         │         ┌───────────────┐          │
         │         │ Rollback path │◀─────────┘
         │         │   alerting    │
         │         └───────────────┘
         ▼
┌────────────┐
│  Observe   │
│  metrics   │
└────────────┘</pre>
            <p class="mt-4 text-xs text-muted-foreground">
              Compose diagrams using monospace boxes; each node includes a
              primary label and a secondary descriptor beneath it.
            </p>
          </div>
        </section>

        <section id="sequence" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">Request sequence</h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              Loop, alt, opt, break, and negative fragments mapped to
              terminal-native sequence notation for the session endpoint.
            </p>
          </header>

          <SequenceDiagram class="space-y-6">
            <Participants>
              <Participant name="Client" color="primary" position="left" />
              <Participant name="Auth API" color="accent" position="right" />
            </Participants>
            <Messages class="space-y-4">
              <CombinedFragment
                type="loop"
                guard="max 3 attempts"
                label="Retry window"
              >
                <CombinedOperand first label="[attempt i]">
                  <Message
                    label="POST /sessions (i)"
                    type="request"
                    direction="right"
                  />
                  <ActivationBox position="right">
                    <CombinedFragment type="alt" label="Credentials valid?">
                      <CombinedOperand first label="[yes]">
                        <Message
                          label="Verify credentials"
                          type="async"
                          direction="left"
                        />
                        <Message
                          label="Persist session"
                          type="async"
                          direction="left"
                        />
                        <Message
                          label="Commit audit log"
                          type="async"
                          direction="left"
                        />
                        <Message
                          label="200 OK + token"
                          type="response"
                          direction="left"
                        />
                      </CombinedOperand>
                      <CombinedOperand label="[no]">
                        <Message
                          label="401 Unauthorized"
                          type="error"
                          direction="left"
                        />
                        <SelfCall
                          label="Increment attempt counter"
                          position="left"
                        />
                        <Note
                          text="State invariant: attempts ≤ 3"
                          position="left"
                        />
                      </CombinedOperand>
                    </CombinedFragment>
                  </ActivationBox>
                </CombinedOperand>
                <CombinedOperand label="[timeout]">
                  <Message
                    label="No response within 30s"
                    type="error"
                    direction="left"
                  />
                  <Note
                    text="Client aborts pending promise and surfaces error."
                    position="center"
                  />
                </CombinedOperand>
              </CombinedFragment>
            </Messages>
            <Note text="State {session == issued}" position="right" />
          </SequenceDiagram>

          <SequenceDiagram class="space-y-6">
            <Participants>
              <Participant name="Client" color="primary" position="left" />
              <Participant name="Auth API" color="accent" position="right" />
            </Participants>
            <Messages class="space-y-4">
              <CombinedFragment type="alt" guard="account locked?">
                <CombinedOperand first label="[locked]">
                  <Message
                    label="Reject immediately"
                    type="error"
                    direction="left"
                  />
                  <Note text="State {status == locked}" position="right" />
                </CombinedOperand>
                <CombinedOperand label="[open]">
                  <CombinedFragment
                    type="opt"
                    guard="user enrolled"
                    label="MFA challenge"
                  >
                    <CombinedOperand first>
                      <Message
                        label="Challenge MFA"
                        type="async"
                        direction="left"
                      />
                      <Message
                        label="MFA verified"
                        type="response"
                        direction="left"
                      />
                    </CombinedOperand>
                  </CombinedFragment>
                  <CombinedFragment
                    type="break"
                    guard="count ≥ 4"
                    label="Lock account"
                  >
                    <CombinedOperand first>
                      <Message
                        label="Flag account"
                        type="async"
                        direction="left"
                      />
                      <Note
                        text="Break aborts remaining flow"
                        position="right"
                      />
                    </CombinedOperand>
                  </CombinedFragment>
                  <Message
                    label="401 Unauthorized"
                    type="error"
                    direction="left"
                  />
                </CombinedOperand>
              </CombinedFragment>
              <CombinedFragment type="neg" label="Invalid signature">
                <CombinedOperand first>
                  <Message
                    label="Alert security bridge"
                    type="async"
                    direction="left"
                  />
                </CombinedOperand>
              </CombinedFragment>
            </Messages>
            <Note
              text="Fragments demonstrate alt/opt/break/neg semantics."
              position="center"
            />
          </SequenceDiagram>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>

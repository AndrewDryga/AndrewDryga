---
import BaseLayout from "@/components/BaseLayout.astro";
import Header from "@/components/Header.astro";
import ComponentLibraryNav from "@/components/ComponentLibraryNav.astro";
import {
  SequenceDiagram,
  Participants,
  Participant,
  Messages,
  Message,
  Note,
  SelfCall,
  ActivationBox,
  CombinedFragment,
  CombinedOperand,
} from "@/components/mdx/SequenceDiagram";
import { SagaDiagram, SagaStep, SagaArrow } from "@/components/mdx/SagaDiagram";
import AsciiStackedBar from "@/components/ascii/StackedBar.astro";
import AsciiVerticalBar from "@/components/ascii/VerticalBar.astro";
import AsciiDiagram from "@/components/mdx/AsciiDiagram.astro";

if (import.meta.env.PROD) {
  return Astro.redirect("/");
}

const site = Astro.site ?? new URL("https://dryga.com/");
const canonical = new URL("/component-library/charts/", site).toString();

const pieSegments = [
  { label: "Build", color: "text-terminal-cyan", value: 34 },
  { label: "QA", color: "text-terminal-green", value: 26 },
  { label: "Deploy", color: "text-terminal-yellow", value: 22 },
  { label: "Ops", color: "text-muted-foreground", value: 18 },
];

const sparklinePoints = [8, 11, 7, 13, 15, 12, 18, 20, 17, 23];

const barSeries = [
  { label: "Mon", value: 6, color: "text-terminal-cyan" },
  { label: "Tue", value: 9, color: "text-terminal-green" },
  { label: "Wed", value: 4, color: "text-terminal-yellow" },
  { label: "Thu", value: 11, color: "text-primary" },
  { label: "Fri", value: 7, color: "text-muted-foreground" },
];

function buildSparkline(points: number[]) {
  const glyphs = ["▁", "▂", "▃", "▅", "▆", "▇", "█"];
  const min = Math.min(...points);
  const max = Math.max(...points);
  return points
    .map((value) => {
      if (max === min) return glyphs[0];
      const normalized = (value - min) / (max - min);
      const index = Math.min(
        glyphs.length - 1,
        Math.floor(normalized * glyphs.length),
      );
      return glyphs[index];
    })
    .join("");
}

const sparkline = buildSparkline(sparklinePoints);
---

<BaseLayout
  title="Component Library — Charts & Flows"
  description="Terminal-native charts, ASCII spark lines, vertical bars, and flow diagrams."
  canonical={canonical}
  noIndex
>
  <Header slot="header" />

  <section class="px-4 py-12 md:py-16">
    <div class="mx-auto flex max-w-6xl flex-col gap-10">
      <ComponentLibraryNav current="charts" />

      <header class="space-y-3">
        <p class="font-mono text-sm text-terminal-green">$ viz charts</p>
        <h1 class="text-4xl md:text-5xl font-bold text-foreground">
          Charts &amp; flows
        </h1>
        <p class="max-w-3xl text-sm text-muted-foreground">
          Compose dashboard-friendly visuals without leaving the terminal
          aesthetic — ASCII pies, spark lines, vertical bars, and annotated
          flows.
        </p>
      </header>

      <div class="space-y-16">
        <section id="stacked" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">
              ASCII stacked bar
            </h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              Horizontal resource split rendered as a single stacked bar so
              proportions stay legible in monospace terminals.
            </p>
          </header>

          <div class="rounded-lg border border-border bg-card p-6">
            <AsciiStackedBar segments={pieSegments} width={32} />
            <p class="mt-6 font-mono text-xs text-muted-foreground">
              Each block represents roughly 3% of the weekly pipeline — tweak
              the weights to match your own mix.
            </p>
          </div>
        </section>

        <section id="sparkline" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">Spark line trend</h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              A week of deployment throughput presented as a single line of
              unicode characters.
            </p>
          </header>

          <div class="rounded-lg border border-border bg-card p-6 font-mono">
            <div class="flex flex-wrap items-baseline gap-3">
              <span class="text-terminal-cyan text-lg tracking-[0.3em]">
                {sparkline}
              </span>
              <span class="text-xs text-muted-foreground">
                min {Math.min(...sparklinePoints)} / max {
                  Math.max(...sparklinePoints)
                }
              </span>
            </div>
            <p class="mt-4 text-xs text-muted-foreground">
              Use the glyph set `▁▂▃▄▅▆▇█` and normalise incoming metrics to map
              values to characters.
            </p>
          </div>
        </section>

        <section id="bars" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">
              ASCII vertical bars
            </h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              Deployment throughput rendered as stacked glyphs — five columns,
              left aligned, no filler.
            </p>
          </header>

          <div class="rounded-lg border border-border bg-card p-6">
            <AsciiVerticalBar bars={barSeries} maxHeight={9} />
            <p class="mt-4 font-mono text-xs text-muted-foreground">
              Each block equals roughly one release per day — tweak <code
                >maxHeight</code
              > to match your scale.
            </p>
          </div>
        </section>

        <section id="flow" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">Deployment flow</h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              Text-only process diagram inspired by the linked example, complete
              with branch annotations.
            </p>
          </header>

          <div
            class="rounded-lg border border-border bg-card p-6 font-mono text-sm leading-relaxed"
          >
            <AsciiDiagram
              label="Deployment flow diagram showing stage build, quality gate, deploy, rollback path, and observe metrics"
              content={`┌─────────────┐    ┌──────────────┐    ┌────────────┐
│ Stage build │───▶│ Quality gate │───▶│   Deploy   │
│    ci/cd    │    │    checks    │    │   fly.io   │
└─────────────┘    └──────────────┘    └────────────┘
         │                 │                  │
         │                 ▼                  │
         │         ┌───────────────┐          │
         │         │ Rollback path │◀─────────┘
         │         │   alerting    │
         │         └───────────────┘
         ▼
┌────────────┐
│  Observe   │
│  metrics   │
└────────────┘`}
            />
            <p class="mt-4 text-xs text-muted-foreground">
              Compose diagrams using monospace boxes; each node includes a
              primary label and a secondary descriptor beneath it.
            </p>
          </div>
        </section>

        <section id="sequence" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">
              Sequence Diagrams
            </h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              World-class sequence diagrams with automatic layout, proper arrow
              routing, self-calls, activation boxes, and fragment support (loop,
              alt, opt, break, neg).
            </p>
          </header>

          <h3 class="text-xl font-semibold text-foreground">
            Basic 2-participant
          </h3>
          <SequenceDiagram>
            <Participants>
              <Participant name="Client" color="accent" />
              <Participant name="Server" color="primary" />
            </Participants>
            <Messages>
              <Message label="Request data" from={0} to={1} />
              <Message label="Process request" from={1} to={1} type="async" />
              <Message label="Return data" from={1} to={0} type="response" />
            </Messages>
            <Note text="Simple request-response pattern" />
          </SequenceDiagram>

          <h3 class="text-xl font-semibold text-foreground">
            3 participants with self-call
          </h3>
          <SequenceDiagram>
            <Participants>
              <Participant name="Client" color="accent" />
              <Participant name="API" color="secondary" />
              <Participant name="Database" color="primary" />
            </Participants>
            <Messages>
              <Message label="POST /users" from={0} to={1} />
              <Message label="Validate input" from={1} to={1} type="async" />
              <Message label="INSERT query" from={1} to={2} />
              <Message label="Row inserted" from={2} to={1} type="response" />
              <Message label="201 Created" from={1} to={0} type="success" />
            </Messages>
            <Note text="Self-call shows internal processing" />
          </SequenceDiagram>

          <h3 class="text-xl font-semibold text-foreground">
            5 participants - complex flow
          </h3>
          <SequenceDiagram>
            <Participants>
              <Participant name="Client" color="accent" />
              <Participant name="API" color="secondary" />
              <Participant name="Queue" color="primary" />
              <Participant name="Worker" color="primary" />
              <Participant name="Storage" color="primary" />
            </Participants>
            <Messages>
              <Message label="Upload file" from={0} to={1} />
              <Message label="Enqueue job" from={1} to={2} />
              <Message label="202 Accepted" from={1} to={0} type="success" />
              <Message label="Dequeue job" from={2} to={3} />
              <Message label="Process file" from={3} to={3} type="async" />
              <Message label="Store result" from={3} to={4} />
              <Message label="Stored" from={4} to={3} type="response" />
              <Message label="Job complete" from={3} to={2} type="success" />
            </Messages>
            <Note text="Demonstrates automatic spacing for 5 participants" />
          </SequenceDiagram>

          <h3 class="text-xl font-semibold text-foreground">
            With activation boxes
          </h3>
          <SequenceDiagram>
            <Participants>
              <Participant name="Client" color="accent" />
              <Participant name="Server" color="primary" />
            </Participants>
            <Messages>
              <Message label="Request" from={0} to={1} />
              <ActivationBox participant={1}>
                <Message label="Validate" from={1} to={1} type="async" />
                <Message label="Process" from={1} to={1} type="async" />
                <Message label="Save" from={1} to={1} type="async" />
              </ActivationBox>
              <Message label="Response" from={1} to={0} type="response" />
            </Messages>
            <Note
              text="Activation box shows when participant is actively processing"
            />
          </SequenceDiagram>

          <h3 class="text-xl font-semibold text-foreground">Error handling</h3>
          <SequenceDiagram>
            <Participants>
              <Participant name="Client" color="accent" />
              <Participant name="API" color="secondary" />
              <Participant name="Database" color="primary" />
            </Participants>
            <Messages>
              <Message label="Create record" from={0} to={1} />
              <Message label="INSERT" from={1} to={2} />
              <Message
                label="Constraint violation"
                from={2}
                to={1}
                type="error"
              />
              <Message label="400 Bad Request" from={1} to={0} type="error" />
            </Messages>
            <Note text="Error type uses dashed lines and error styling" />
          </SequenceDiagram>

          <h3 class="text-xl font-semibold text-foreground">
            Advanced: Fragments
          </h3>

          <SequenceDiagram class="space-y-6">
            <Participants>
              <Participant name="Client" color="primary" position="left" />
              <Participant name="Auth API" color="accent" position="right" />
            </Participants>
            <Messages class="space-y-4">
              <CombinedFragment
                type="loop"
                guard="max 3 attempts"
                label="Retry window"
              >
                <CombinedOperand first label="[attempt i]">
                  <Message
                    label="POST /sessions (i)"
                    type="request"
                    direction="right"
                  />
                  <ActivationBox position="right">
                    <CombinedFragment type="alt" label="Credentials valid?">
                      <CombinedOperand first label="[yes]">
                        <Message
                          label="Verify credentials"
                          type="async"
                          direction="left"
                        />
                        <Message
                          label="Persist session"
                          type="async"
                          direction="left"
                        />
                        <Message
                          label="Commit audit log"
                          type="async"
                          direction="left"
                        />
                        <Message
                          label="200 OK + token"
                          type="response"
                          direction="left"
                        />
                      </CombinedOperand>
                      <CombinedOperand label="[no]">
                        <Message
                          label="401 Unauthorized"
                          type="error"
                          direction="left"
                        />
                        <SelfCall
                          label="Increment attempt counter"
                          participant={0}
                        />
                        <Note
                          text="State invariant: attempts ≤ 3"
                          position="left"
                        />
                      </CombinedOperand>
                    </CombinedFragment>
                  </ActivationBox>
                </CombinedOperand>
                <CombinedOperand label="[timeout]">
                  <Message
                    label="No response within 30s"
                    type="error"
                    direction="left"
                  />
                  <Note
                    text="Client aborts pending promise and surfaces error."
                    position="center"
                  />
                </CombinedOperand>
              </CombinedFragment>
            </Messages>
            <Note text="State {session == issued}" position="right" />
          </SequenceDiagram>

          <SequenceDiagram class="space-y-6">
            <Participants>
              <Participant name="Client" color="primary" position="left" />
              <Participant name="Auth API" color="accent" position="right" />
            </Participants>
            <Messages class="space-y-4">
              <CombinedFragment type="alt" guard="account locked?">
                <CombinedOperand first label="[locked]">
                  <Message
                    label="Reject immediately"
                    type="error"
                    direction="left"
                  />
                  <Note text="State {status == locked}" position="right" />
                </CombinedOperand>
                <CombinedOperand label="[open]">
                  <CombinedFragment
                    type="opt"
                    guard="user enrolled"
                    label="MFA challenge"
                  >
                    <CombinedOperand first>
                      <Message
                        label="Challenge MFA"
                        type="async"
                        direction="left"
                      />
                      <Message
                        label="MFA verified"
                        type="response"
                        direction="left"
                      />
                    </CombinedOperand>
                  </CombinedFragment>
                  <CombinedFragment
                    type="break"
                    guard="count ≥ 4"
                    label="Lock account"
                  >
                    <CombinedOperand first>
                      <Message
                        label="Flag account"
                        type="async"
                        direction="left"
                      />
                      <Note
                        text="Break aborts remaining flow"
                        position="right"
                      />
                    </CombinedOperand>
                  </CombinedFragment>
                  <Message
                    label="401 Unauthorized"
                    type="error"
                    direction="left"
                  />
                </CombinedOperand>
              </CombinedFragment>
              <CombinedFragment type="neg" label="Invalid signature">
                <CombinedOperand first>
                  <Message
                    label="Alert security bridge"
                    type="async"
                    direction="left"
                  />
                </CombinedOperand>
              </CombinedFragment>
            </Messages>
            <Note
              text="Fragments demonstrate alt/opt/break/neg semantics."
              position="center"
            />
          </SequenceDiagram>
        </section>

        <section id="saga" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">Saga diagram</h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              Visualise distributed transaction flows with forward steps
              (transactions) and reverse steps (compensations) aligned
              vertically. Supports failure markers, vertical connectors, step
              labels, and parallel groups.
            </p>
          </header>

          <h3 class="text-xl font-semibold text-foreground">
            Linear saga with failure
          </h3>
          <SagaDiagram title="Trip booking — flight fails at step 4">
            <SagaStep
              tx={"Fetch currency\nexchange rates"}
              txStatus="success"
              comp={"Send\nexcuse letter"}
              compStatus="inactive"
            />
            <SagaArrow showTx txLabel="1" />
            <SagaStep
              tx={"Pre-authorize\ncard"}
              txStatus="success"
              comp={"Cancel pre-\nauthorization"}
              compStatus="warning"
            />
            <SagaArrow showTx txLabel="2" showComp compLabel="8" />
            <SagaStep
              tx={"Book\nhotel"}
              txStatus="success"
              comp={"Cancel\nhotel booking"}
              compStatus="warning"
            />
            <SagaArrow showTx txLabel="3" showComp compLabel="7" />
            <SagaStep
              tx={"Book\ncar"}
              txStatus="success"
              comp={"Cancel\ncar booking"}
              compStatus="warning"
            />
            <SagaArrow showTx txLabel="4" showComp compLabel="6" />
            <SagaStep
              tx={"Book\nflight"}
              txStatus="fail"
              comp={"Ensure flight\nis not booked"}
              compStatus="warning"
              vline
              vlineLabel="5"
            />
            <SagaArrow />
            <SagaStep
              tx={"Send email\nconfirmation"}
              txStatus="inactive"
              comp={"Refund\npayment"}
              compStatus="inactive"
            />
            <SagaArrow />
            <SagaStep tx="Charge card" txStatus="inactive" />
          </SagaDiagram>

          <h3 class="text-xl font-semibold text-foreground">Parallel steps</h3>
          <SagaDiagram title="Concurrent bookings with partial failure">
            <SagaStep
              tx={"Fetch currency\nexchange rates"}
              txStatus="success"
              comp={"Send\nexcuse letter"}
              compStatus="inactive"
            />
            <SagaArrow showTx txLabel="1" />
            <SagaStep
              tx={"Pre-authorize\ncard"}
              txStatus="success"
              comp={"Cancel pre-\nauthorization"}
              compStatus="warning"
            />
            <SagaArrow showTx txLabel="2,3,4" showComp compLabel="8" />
            <SagaStep
              tx={["Book\nflight", "Book\nhotel", "Book\ncar"]}
              txStatus={["success", "fail", "success"]}
              comp={[
                "Ensure flight\nis not booked",
                "Cancel\nhotel booking",
                "Cancel\ncar booking",
              ]}
              compStatus="warning"
              vline
              vlineLabel="5"
            />
            <SagaArrow showComp compLabel="7,6" />
            <SagaStep
              tx={"Send email\nconfirmation"}
              txStatus="inactive"
              comp={"Refund\npayment"}
              compStatus="inactive"
            />
            <SagaArrow />
            <SagaStep tx="Charge card" txStatus="inactive" />
          </SagaDiagram>

          <h3 class="text-xl font-semibold text-foreground">Minimal</h3>
          <SagaDiagram>
            <SagaStep
              tx="Create user"
              txStatus="success"
              comp="Delete user"
              compStatus="warning"
            />
            <SagaArrow showTx txLabel="1" showComp compLabel="2" />
            <SagaStep tx="Send email" txStatus="fail" vline />
          </SagaDiagram>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>

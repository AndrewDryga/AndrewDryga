---
import BaseLayout from "@/components/BaseLayout.astro";
import Header from "@/components/Header.astro";
import ComponentLibraryNav from "@/components/ComponentLibraryNav.astro";
import Button from "@/components/ui/Button.astro";
import ComboboxField from "@/components/ui/ComboboxField.astro";
import TerminalForm from "@/components/ui/TerminalForm.astro";
import Input from "@/components/ui/Input.astro";
import Label from "@/components/ui/Label.astro";
import Textarea from "@/components/ui/Textarea.astro";
import Checkbox from "@/components/ui/Checkbox.astro";
import RadioGroup from "@/components/ui/RadioGroup.astro";
import Switch from "@/components/ui/Switch.astro";
import Select from "@/components/ui/Select.astro";
import Slider from "@/components/ui/Slider.astro";
import InputOtp from "@/components/ui/InputOtp.astro";
import FormField from "@/components/ui/FormField.astro";

if (import.meta.env.PROD) {
  return Astro.redirect("/");
}

const site = Astro.site ?? new URL("https://dryga.com/");
const canonical = new URL("/component-library/forms/", site).toString();

const frameworks = [
  { value: "astro", label: "Astro" },
  { value: "svelte", label: "Svelte" },
  { value: "solid", label: "Solid" },
  { value: "vue", label: "Vue" },
];

const checklist = [
  "Associate every input with a visual label.",
  "Group related fields with fieldsets and monospace legends.",
  "Signal success and error states with both color and iconography.",
  "Never rely solely on placeholder text for context.",
];
---

<BaseLayout
  title="Component Library - Form Patterns"
  description="Terminal-themed forms, validation patterns, and inline scripting that work without React."
  canonical={canonical}
  noIndex
>
  <Header slot="header" />

  <section class="px-4 py-12 md:py-16">
    <div class="mx-auto flex max-w-6xl flex-col gap-10">
      <ComponentLibraryNav current="forms" />

      <header class="space-y-3">
        <p class="font-mono text-sm text-terminal-green">$ forms --list</p>
        <h1 class="text-4xl md:text-5xl font-bold text-foreground">
          Form patterns
        </h1>
        <p class="max-w-3xl text-sm text-muted-foreground">
          Copy-paste ready form layouts with zero-client validation hooks,
          focus-visible states, and terminal-friendly styling tokens.
        </p>
      </header>

      <div class="space-y-16">
        <section id="playground" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">
              Interactive playground
            </h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              Swap frameworks, reset notes, and preview terminal-themed text
              areas without leaving the page.
            </p>
          </header>

          <article
            class="rounded-lg border border-border bg-card/40 p-6 shadow-card"
          >
            <header class="mb-6 space-y-2">
              <p class="font-mono text-sm text-terminal-green">
                $ node forms/playground.ts
              </p>
              <h3 class="text-2xl font-semibold text-foreground">
                Inline configuration
              </h3>
              <p class="text-sm text-muted-foreground">
                Lightweight interactivity handled with a sprinkle of inline
                script. Ideal for demos that shouldn’t ship additional bundles.
              </p>
            </header>

            <form class="space-y-4" data-playground-form>
              <label class="block">
                <span
                  class="font-mono text-xs uppercase tracking-wide text-muted-foreground"
                >
                  Framework
                </span>
                <div class="relative mt-2">
                  <select
                    name="framework"
                    class="w-full appearance-none rounded border border-border bg-terminal-surface px-4 py-2 pr-10 font-mono text-sm text-foreground focus:border-terminal-cyan focus:outline-none focus:ring-1 focus:ring-terminal-cyan"
                  >
                    {
                      frameworks.map((fw) => (
                        <option value={fw.value}>{fw.label}</option>
                      ))
                    }
                  </select>
                  <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-terminal-cyan">
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg>
                  </span>
                </div>
              </label>

              <label class="block">
                <span
                  class="font-mono text-xs uppercase tracking-wide text-muted-foreground"
                >
                  Notes
                </span>
                <textarea
                  name="notes"
                  rows={3}
                  class="mt-2 w-full rounded border border-border bg-background px-3 py-2 font-mono text-sm text-foreground focus:border-terminal-cyan focus:outline-none focus:ring-2 focus:ring-terminal-cyan"
                  placeholder="What would you build with this pattern?"
                ></textarea>
              </label>

              <div class="flex flex-wrap items-center gap-3">
                <Button
                  type="button"
                  variant="outline"
                  size="sm"
                  class="gap-2 border-terminal-cyan text-terminal-cyan hover:bg-terminal-cyan hover:text-background"
                  data-playground-clear
                >
                  Clear notes
                </Button>
                <span class="font-mono text-xs text-muted-foreground">
                  Selected:
                  <span data-playground-selected class="text-terminal-green">
                    Astro
                  </span>
                </span>
              </div>
            </form>
          </article>
        </section>

        <section id="form-elements" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">
              Form building blocks
            </h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              Inputs, toggles, radios, selects, and submission feedback styled
              to mirror the production contact form.
            </p>
          </header>

          <form
            data-component-form
            class="bg-card border border-border rounded-lg p-6 space-y-6"
          >
            <label class="block">
              <span class="block text-sm font-mono text-foreground mb-2">
                $ Name
              </span>
              <input
                name="name"
                type="text"
                placeholder="Enter your name..."
                class="w-full px-4 py-2 bg-input border border-border rounded text-foreground font-mono focus:outline-none focus:border-terminal-cyan focus:ring-1 focus:ring-terminal-cyan transition-colors"
                required
              />
            </label>

            <div class="grid gap-6 md:grid-cols-2">
              <label class="block">
                <span class="block text-sm font-mono text-foreground mb-2">
                  $ Email
                </span>
                <input
                  name="email"
                  type="email"
                  placeholder="dev@terminal.app"
                  class="w-full px-4 py-2 bg-input border border-border rounded text-foreground font-mono focus:outline-none focus:border-terminal-cyan focus:ring-1 focus:ring-terminal-cyan transition-colors"
                  required
                />
              </label>
              <label class="block">
                <span class="block text-sm font-mono text-foreground mb-2">
                  $ Company
                </span>
                <input
                  name="company"
                  type="text"
                  placeholder="Orbital Systems"
                  class="w-full px-4 py-2 bg-input border border-border rounded text-foreground font-mono focus:outline-none focus:border-terminal-cyan focus:ring-1 focus:ring-terminal-cyan transition-colors"
                />
              </label>
            </div>

            <label class="block">
              <span class="block text-sm font-mono text-foreground mb-2">
                $ Message
              </span>
              <textarea
                name="message"
                rows={4}
                placeholder="Your message here..."
                class="w-full px-4 py-2 bg-input border border-border rounded text-foreground font-mono focus:outline-none focus:border-terminal-cyan focus:ring-1 focus:ring-terminal-cyan transition-colors resize-none"
              ></textarea>
            </label>

            <fieldset class="space-y-2 rounded-lg border border-border p-4">
              <legend
                class="px-2 font-mono text-xs uppercase tracking-wide text-muted-foreground"
              >
                Preferences
              </legend>
              <label class="flex items-center gap-3 cursor-pointer">
                <input type="checkbox" name="newsletter" class="peer sr-only" />
                <span
                  class="w-5 h-5 border-2 border-border rounded flex items-center justify-center peer-checked:border-terminal-cyan transition-colors"
                >
                  <span
                    class="w-3 h-3 bg-terminal-cyan rounded-sm opacity-0 peer-checked:opacity-100 transition-opacity"
                  ></span>
                </span>
                <span class="text-foreground font-mono text-sm">
                  Subscribe to updates
                </span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer">
                <input type="checkbox" name="beta" class="peer sr-only" />
                <span
                  class="w-5 h-5 border-2 border-border rounded flex items-center justify-center peer-checked:border-terminal-cyan transition-colors"
                >
                  <span
                    class="w-3 h-3 bg-terminal-cyan rounded-sm opacity-0 peer-checked:opacity-100 transition-opacity"
                  ></span>
                </span>
                <span class="text-foreground font-mono text-sm">
                  Join beta channel
                </span>
              </label>
            </fieldset>

            <fieldset class="space-y-2 rounded-lg border border-border p-4">
              <legend
                class="px-2 font-mono text-xs uppercase tracking-wide text-muted-foreground"
              >
                Experience level
              </legend>
              {
                ["beginner", "intermediate", "advanced"].map((level) => (
                  <label class="flex items-center gap-3 cursor-pointer capitalize">
                    <input
                      type="radio"
                      name="experience"
                      value={level}
                      class="peer sr-only"
                      checked={level === "intermediate"}
                    />
                    <span class="w-5 h-5 border-2 border-border rounded-full flex items-center justify-center peer-checked:border-terminal-cyan transition-colors">
                      <span class="w-3 h-3 bg-terminal-cyan rounded-full opacity-0 peer-checked:opacity-100 transition-opacity" />
                    </span>
                    <span class="text-foreground font-mono text-sm">
                      {level}
                    </span>
                  </label>
                ))
              }
            </fieldset>

            <div class="grid gap-6 md:grid-cols-2">
              <label class="block">
                <span class="block text-sm font-mono text-foreground mb-2">
                  $ Framework
                </span>
                <div class="relative">
                  <select
                    name="framework"
                    class="w-full appearance-none rounded border border-border bg-terminal-surface px-4 py-2 pr-10 font-mono text-sm text-foreground focus:border-terminal-cyan focus:outline-none focus:ring-1 focus:ring-terminal-cyan"
                  >
                    <option value="astro">Astro</option>
                    <option value="svelte">Svelte</option>
                    <option value="solid">Solid</option>
                    <option value="vue">Vue</option>
                  </select>
                  <span
                    class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-terminal-cyan"
                  >
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg>
                  </span>
                </div>
              </label>
              <label class="block">
                <span class="block text-sm font-mono text-foreground mb-2">
                  $ Budget
                </span>
                <input
                  type="number"
                  name="budget"
                  min="0"
                  placeholder="25000"
                  class="w-full px-4 py-2 bg-input border border-border rounded text-foreground font-mono focus:outline-none focus:border-terminal-cyan focus:ring-1 focus:ring-terminal-cyan transition-colors"
                />
              </label>
            </div>

            <div class="grid gap-6 md:grid-cols-2">
              <ComboboxField
                name="framework_search"
                label="$ Framework (searchable)"
                options={frameworks}
                defaultValue="astro"
                searchPlaceholder="Search frameworks..."
                class="font-mono text-sm"
              />
            </div>

            <Button type="submit" class="w-full md:w-auto px-6 py-2">
              Submit form
            </Button>
          </form>

          <div
            data-form-result
            hidden
            class="mt-6 border border-accent rounded-lg p-6 bg-card"
          >
            <div class="font-mono text-terminal-cyan mb-2">
              $ Form submitted successfully!
            </div>
            <div class="font-mono text-sm space-y-1 text-foreground">
              <div>Name: <span data-form-output="name"></span></div>
              <div>Email: <span data-form-output="email"></span></div>
              <div>Company: <span data-form-output="company"></span></div>
              <div>Message: <span data-form-output="message"></span></div>
              <div>Framework: <span data-form-output="framework"></span></div>
              <div>
                Search select: <span data-form-output="framework_search"></span>
              </div>
              <div>Newsletter: <span data-form-output="newsletter"></span></div>
              <div>Beta: <span data-form-output="beta"></span></div>
              <div>Experience: <span data-form-output="experience"></span></div>
              <div>Budget: <span data-form-output="budget"></span></div>
            </div>
          </div>
        </section>

        <section id="guidelines" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">
              Validation checklist
            </h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              Guardrails to keep forms accessible and consistent with the
              terminal aesthetic.
            </p>
          </header>

          <div class="grid gap-4 md:grid-cols-2">
            <div
              class="rounded-lg border border-terminal-cyan/40 bg-terminal-surface/70 p-5"
            >
              <h3
                class="font-mono text-xs uppercase tracking-wide text-terminal-cyan mb-3"
              >
                Required
              </h3>
              <ul class="space-y-2 text-sm text-foreground font-mono">
                {
                  checklist.map((item) => (
                    <li class="flex gap-2">
                      <span class="text-terminal-green">✓</span>
                      <span>{item}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
            <div
              class="rounded-lg border border-terminal-yellow/40 bg-terminal-surface/70 p-5"
            >
              <h3
                class="font-mono text-xs uppercase tracking-wide text-terminal-yellow mb-3"
              >
                Nice to have
              </h3>
              <ul class="space-y-2 text-sm text-foreground font-mono">
                <li class="flex gap-2">
                  <span class="text-terminal-yellow">•</span>
                  Provide inline feedback within 500ms.
                </li>
                <li class="flex gap-2">
                  <span class="text-terminal-yellow">•</span>
                  Mirror server validation messages on the client.
                </li>
                <li class="flex gap-2">
                  <span class="text-terminal-yellow">•</span>
                  Animate focus transitions with minimal easing.
                </li>
              </ul>
            </div>
          </div>
        </section>

        <section id="primitives" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">
              Form primitives
            </h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              Reusable building-block components for inputs, labels, selects,
              and toggles. Each maps to a single Astro file with terminal
              styling baked in.
            </p>
          </header>

          <div class="space-y-8">
            <div class="bg-card border border-border rounded-lg p-6 space-y-6">
              <h3 class="text-lg font-semibold text-foreground">Input &amp; Label</h3>
              <div class="grid gap-6 md:grid-cols-2">
                <FormField label="Full name" htmlFor="demo-name">
                  <Input id="demo-name" name="demo-name" placeholder="Jane Doe" />
                </FormField>
                <FormField label="Email address" htmlFor="demo-email" description="We'll never share your email.">
                  <Input id="demo-email" name="demo-email" type="email" placeholder="jane@example.com" />
                </FormField>
              </div>
              <FormField label="Bio" htmlFor="demo-bio">
                <Textarea id="demo-bio" name="demo-bio" placeholder="Tell us about yourself..." rows={3} />
              </FormField>
              <FormField label="API token" htmlFor="demo-token" error="Token has expired. Generate a new one.">
                <Input id="demo-token" name="demo-token" value="sk_expired_abc123" class="border-destructive" />
              </FormField>
              <p class="text-xs text-muted-foreground font-mono">
                FormField wraps Label + description + error messaging. Input and Textarea accept all native attributes.
              </p>
            </div>

            <div class="bg-card border border-border rounded-lg p-6 space-y-6">
              <h3 class="text-lg font-semibold text-foreground">Select</h3>
              <div class="grid gap-6 md:grid-cols-2">
                <FormField label="Region" htmlFor="demo-region">
                  <Select
                    name="demo-region"
                    options={[
                      { label: "US East", value: "us-east-1" },
                      { label: "US West", value: "us-west-2" },
                      { label: "EU West", value: "eu-west-1" },
                      { label: "AP Southeast", value: "ap-southeast-1" },
                    ]}
                    placeholder="Choose a region..."
                  />
                </FormField>
                <FormField label="Environment" htmlFor="demo-env">
                  <Select
                    name="demo-env"
                    options={[
                      { label: "Development", value: "dev" },
                      { label: "Staging", value: "staging" },
                      { label: "Production", value: "production" },
                    ]}
                    placeholder="Target environment"
                  />
                </FormField>
              </div>
            </div>

            <div class="bg-card border border-border rounded-lg p-6 space-y-6">
              <h3 class="text-lg font-semibold text-foreground">Checkbox &amp; Switch</h3>
              <div class="grid gap-6 md:grid-cols-2">
                <div class="space-y-3">
                  <Label class="text-sm font-mono">Notifications</Label>
                  <div class="space-y-2">
                    <Checkbox name="notify-email" checked>Email alerts</Checkbox>
                    <Checkbox name="notify-slack">Slack messages</Checkbox>
                    <Checkbox name="notify-sms" disabled>SMS (coming soon)</Checkbox>
                  </div>
                </div>
                <div class="space-y-3">
                  <Label class="text-sm font-mono">Feature flags</Label>
                  <div class="space-y-3">
                    <Switch name="dark-mode" label="Dark mode" checked />
                    <Switch name="analytics" label="Analytics" />
                    <Switch name="beta" label="Beta features" />
                  </div>
                </div>
              </div>
            </div>

            <div class="bg-card border border-border rounded-lg p-6 space-y-6">
              <h3 class="text-lg font-semibold text-foreground">Radio group</h3>
              <div class="grid gap-6 md:grid-cols-2">
                <RadioGroup
                  name="plan"
                  defaultValue="pro"
                  options={[
                    { label: "Free", value: "free", description: "Up to 3 projects" },
                    { label: "Pro", value: "pro", description: "Unlimited projects" },
                    { label: "Enterprise", value: "enterprise", description: "Custom SLA & support" },
                  ]}
                />
                <RadioGroup
                  name="deploy-target"
                  defaultValue="cloudflare"
                  options={[
                    { label: "Cloudflare Workers", value: "cloudflare" },
                    { label: "Vercel Edge", value: "vercel" },
                    { label: "Fly.io", value: "fly" },
                  ]}
                />
              </div>
            </div>

            <div class="bg-card border border-border rounded-lg p-6 space-y-6">
              <h3 class="text-lg font-semibold text-foreground">Slider</h3>
              <div class="grid gap-6 md:grid-cols-2">
                <FormField label="Replicas" htmlFor="demo-replicas">
                  <Slider name="demo-replicas" min={1} max={10} step={1} value={3} />
                </FormField>
                <FormField label="CPU limit (%)" htmlFor="demo-cpu">
                  <Slider name="demo-cpu" min={0} max={100} step={5} value={75} />
                </FormField>
              </div>
            </div>

            <div class="bg-card border border-border rounded-lg p-6 space-y-6">
              <h3 class="text-lg font-semibold text-foreground">OTP input</h3>
              <FormField label="Verification code" description="Enter the 6-digit code from your authenticator app.">
                <InputOtp name="demo-otp" length={6} />
              </FormField>
            </div>
          </div>
        </section>

        <section id="terminal-form" class="space-y-6">
          <header class="space-y-3">
            <h2 class="text-3xl font-bold text-foreground">
              Terminal form
            </h2>
            <p class="text-sm text-muted-foreground max-w-2xl">
              A step-by-step CLI wizard that collects input one question at a
              time. Supports validation, confirmation, and POST submission.
            </p>
          </header>

          <TerminalForm
            id="demo"
            title="survey.sh"
            steps={[
              { key: "name", label: "Your name?", type: "text" },
              {
                key: "email",
                label: "Your email?",
                type: "email",
                pattern: "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$",
                error: "Please enter a valid email address.",
              },
              { key: "feedback", label: "Any feedback?", type: "text" },
            ]}
            confirm={{ label: "Submit? (y/n)" }}
            successMessage="Thanks for the feedback!"
          >
            <Fragment slot="preamble">
              <div class="text-terminal-green">$ ./survey.sh</div>
              <div class="text-muted-foreground">Starting survey...</div>
            </Fragment>
          </TerminalForm>

          <div
            class="rounded-lg border border-border bg-card p-6 font-mono text-sm space-y-4"
          >
            <h3 class="text-foreground font-bold text-base">Usage</h3>
            <pre class="text-muted-foreground overflow-x-auto"><code>{`<TerminalForm
  id="contact"
  title="contact.sh"
  steps={[
    { key: "name", label: "Your name?", type: "text" },
    {
      key: "email",
      label: "Email?",
      type: "email",
      pattern: "^[^\\\\s@]+@[^\\\\s@]+\\\\.[^\\\\s@]+$",
      error: "Invalid email.",
    },
    { key: "message", label: "Message:", type: "text" },
  ]}
  action="/api/contact"
  confirm={{ label: "Send? (y/n)" }}
  successMessage="Sent!"
>
  <Fragment slot="preamble">
    <div class="text-terminal-green">$ ./contact.sh</div>
  </Fragment>
</TerminalForm>`}</code></pre>

            <h3 class="text-foreground font-bold text-base mt-6">Props</h3>
            <div class="overflow-x-auto">
              <table class="w-full text-left text-sm">
                <thead>
                  <tr class="border-b border-border text-muted-foreground">
                    <th class="py-2 pr-4">Prop</th>
                    <th class="py-2 pr-4">Type</th>
                    <th class="py-2 pr-4">Default</th>
                    <th class="py-2">Description</th>
                  </tr>
                </thead>
                <tbody class="text-foreground/80">
                  <tr class="border-b border-border/40">
                    <td class="py-2 pr-4 text-terminal-cyan">id</td>
                    <td class="py-2 pr-4">string</td>
                    <td class="py-2 pr-4">—</td>
                    <td class="py-2">Unique ID (required)</td>
                  </tr>
                  <tr class="border-b border-border/40">
                    <td class="py-2 pr-4 text-terminal-cyan">title</td>
                    <td class="py-2 pr-4">string</td>
                    <td class="py-2 pr-4">"form.sh"</td>
                    <td class="py-2">Title bar text</td>
                  </tr>
                  <tr class="border-b border-border/40">
                    <td class="py-2 pr-4 text-terminal-cyan">steps</td>
                    <td class="py-2 pr-4">Step[]</td>
                    <td class="py-2 pr-4">—</td>
                    <td class="py-2">Questions to ask (key, label, type, pattern, error)</td>
                  </tr>
                  <tr class="border-b border-border/40">
                    <td class="py-2 pr-4 text-terminal-cyan">action</td>
                    <td class="py-2 pr-4">string</td>
                    <td class="py-2 pr-4">—</td>
                    <td class="py-2">POST URL. If omitted, dispatches a custom event instead</td>
                  </tr>
                  <tr class="border-b border-border/40">
                    <td class="py-2 pr-4 text-terminal-cyan">confirm</td>
                    <td class="py-2 pr-4">object | false</td>
                    <td class="py-2 pr-4">"Confirm? (y/n)"</td>
                    <td class="py-2">Confirm step config, or false to skip</td>
                  </tr>
                  <tr class="border-b border-border/40">
                    <td class="py-2 pr-4 text-terminal-cyan">successMessage</td>
                    <td class="py-2 pr-4">string</td>
                    <td class="py-2 pr-4">"Done!"</td>
                    <td class="py-2">Success text</td>
                  </tr>
                  <tr>
                    <td class="py-2 pr-4 text-terminal-cyan">errorMessage</td>
                    <td class="py-2 pr-4">string</td>
                    <td class="py-2 pr-4">"Something went wrong..."</td>
                    <td class="py-2">Error text</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const form = document.querySelector("[data-playground-form]");
    if (!form) return;

    const select = form.querySelector("select[name='framework']");
    const notes = form.querySelector("textarea[name='notes']");
    const selected = form.querySelector("[data-playground-selected]");
    const clear = form.querySelector("[data-playground-clear]");

    if (!(select instanceof HTMLSelectElement)) return;
    if (!(notes instanceof HTMLTextAreaElement)) return;
    if (!(selected instanceof HTMLElement)) return;
    if (!(clear instanceof HTMLElement)) return;

    const updateLabel = () => {
      const option = select.options[select.selectedIndex];
      selected.textContent = option?.text ?? "Astro";
    };

    select.addEventListener("change", updateLabel);
    clear.addEventListener("click", () => {
      notes.value = "";
      notes.focus();
    });

    updateLabel();
  })();
</script>

<script is:inline>
  (() => {
    const form = document.querySelector("[data-component-form]");
    if (!(form instanceof HTMLFormElement)) return;
    const result = document.querySelector("[data-form-result]");
    if (!(result instanceof HTMLElement)) return;

    const output = (key) => result.querySelector(`[data-form-output='${key}']`);
    const assign = (key, value) => {
      const target = output(key);
      if (target) target.textContent = value;
    };

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const read = (key, fallback = "") => {
        const value = formData.get(key);
        return value == null ? fallback : String(value);
      };

      assign("name", read("name"));
      assign("email", read("email"));
      assign("company", read("company", "-"));
      assign("message", read("message", "-"));
      assign("framework", read("framework", "Astro"));
      assign("framework_search", read("framework_search", "astro"));
      assign("newsletter", formData.get("newsletter") === "on" ? "Yes" : "No");
      assign("beta", formData.get("beta") === "on" ? "Enabled" : "Disabled");
      assign("experience", read("experience", "intermediate"));
      assign("budget", read("budget", "-"));

      result.removeAttribute("hidden");
      result.scrollIntoView({ behavior: "smooth", block: "center" });
    });
  })();
</script>

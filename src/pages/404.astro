---
import BaseLayout from "../components/BaseLayout.astro";
import Header from "../components/Header.astro";

const title = "404 - Page Not Found";
const description =
  "The page you’re looking for doesn’t exist. Try the home page or blog.";
const canonical = undefined; // Let BaseLayout derive canonical from current URL
const noIndex = true;
---

<BaseLayout {title} {description} {canonical} {noIndex}>
  <Header slot="header" variant="header" />
  <section class="min-h-[70vh] flex items-center justify-center px-4 py-16 md:py-24">
    <div class="max-w-3xl w-full text-center space-y-8">
      <!-- Main heading -->
      <div class="space-y-3">
        <h1 class="text-4xl md:text-6xl font-bold font-sans">
          <span class="text-foreground">Page not found</span><span class="text-terminal-cyan">.</span>
        </h1>
        <p class="text-muted-foreground max-w-xl mx-auto">
          The page you’re looking for doesn’t exist or has moved.
          You can head back home or read the blog.
        </p>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row flex-wrap gap-3 sm:gap-4 justify-center pt-2">
        <a
          href="/"
          class="inline-flex items-center justify-center font-mono border-2 border-terminal-cyan bg-transparent text-terminal-cyan hover:bg-terminal-cyan hover:text-background transition-all shadow-glow rounded-md px-5 py-3"
        >
          ← Home
        </a>

        <a
          href="/blog/"
          class="inline-flex items-center justify-center font-mono border-2 border-terminal-yellow text-terminal-yellow hover:bg-terminal-yellow hover:text-background transition-all rounded-md px-5 py-3"
        >
          Blog
        </a>
      </div>

      <!-- Decorative hint -->
      <div class="pt-2 font-mono text-terminal-cyan/50 text-sm" id="hint">
        <span class="text-terminal-cyan">&gt;_</span>
        <span id="hint-text"></span><span class="animate-pulse" aria-hidden="true">▊</span>
      </div>
      <script is:inline>
        (function () {
          const el = document.getElementById("hint-text");
          if (!el) return;
          const messages = [
            "Check the path - it currently resolves to /dev/null. Great sink, terrible page.",
            "Smash Tab like a pro; autocomplete is the real senior engineer here.",
            "Use an absolute path; your relatives keep wandering off.",
            "Count your slashes - you’ve got a classic off-by-one fencepost bug.",
            "Respect the casing; our server is case-sensitive and emotionally unavailable.",
            "Try /v2; /v1 retired to “write a tech blog.”",
            "Purge zero-width spaces; invisible Unicode, visible chaos.",
            "DNS also shrugged - double-check the hostname before it ghosts you.",
            "This route isn’t in $PATH; export better life choices.",
            "Don’t sudo the URL - just fix the spelling.",
            "We containerized this page and forgot the port mapping; try a different path.",
            "YAML ate the indent that used to point here - unmix your spaces and tabs.",
            "Your query string looks base64’d twice; maybe decode your enthusiasm.",
            "Try https; http got rate-limited by time.",
            "The endpoint is behind a feature flag named NOT_READY_YET; choose a path that exists.",
            "Symlink detected - to disappointment. Point it somewhere real.",
            "Git blames you (gently). Rename that kebab/camelCase to match the route.",
            "Router says ¯\\_(ツ)_/¯; fewer emojis, more path.",
            "Run ls in your brain and pick something that actually shows up.",
            "Hit Ctrl+U and retype - fresh start, fresh path, fewer tears."
          ];
          let prev = null;
          const typeDelay = 45;           // slower typing (fast human)
          const eraseDelay = 28;          // erase a bit faster than typing
          const holdAfterType = 5000;     // keep the text visible for 5s
          const pauseBeforeStart = 500;   // small delay before first type
          const pauseBetween = 800;       // pause between cycles
          let msg = "";
          let i = 0;

          function pickMessage() {
            if (messages.length === 0) return "";
            let next = messages[Math.floor(Math.random() * messages.length)];
            if (messages.length > 1) {
              while (next === prev) {
                next = messages[Math.floor(Math.random() * messages.length)];
              }
            }
            prev = next;
            return next;
          }

          function start() {
            msg = pickMessage();
            i = 0;
            type();
          }

          function type() {
            if (i <= msg.length) {
              el.textContent = msg.slice(0, i++);
              setTimeout(type, typeDelay);
            } else {
              setTimeout(erase, holdAfterType);
            }
          }

          function erase() {
            if (i >= 0) {
              el.textContent = msg.slice(0, i--);
              setTimeout(erase, eraseDelay);
            } else {
              el.textContent = "";
              setTimeout(start, pauseBetween);
            }
          }

          setTimeout(start, pauseBeforeStart);
        })();
      </script>
    </div>
  </section>
  <Header slot="footer" variant="footer" />
</BaseLayout>

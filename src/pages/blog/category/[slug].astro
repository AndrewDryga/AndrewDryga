---
import BaseLayout from "../../../components/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import SectionHeader from "../../../components/SectionHeader.astro";
import {
  getBlogCategories,
  loadBlogSummaries,
  formatPublishDate,
} from "../../../lib/blog";

// Generate static paths for each category (except "All")
export async function getStaticPaths() {
  const posts = await loadBlogSummaries();
  const slugs = getBlogCategories(posts).map((c) =>
    c.toLowerCase().replace(/\s+/g, "-"),
  );

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

const allPosts = await loadBlogSummaries();
const categoryList = getBlogCategories(allPosts);
const categories = ["All", ...categoryList];
const slugToCategory = new Map(
  categoryList.map((c) => [c.toLowerCase().replace(/\s+/g, "-"), c]),
);

const currentCategory = slug ? (slugToCategory.get(slug) ?? null) : null;

if (!currentCategory) {
  // Unknown category -> go back to blog index
  return Astro.redirect("/blog/");
}

const CATEGORY_INTRO: Record<string, string> = {
  Architecture:
    "Practical architecture notes from systems that shipped. Trade-offs, diagrams, and patterns that stayed simple under real load.",
  Engineering:
    "Hands-on product engineering from idea to production. Thin slices, fast feedback, and code that’s easy to change.",
  Security:
    "Pragmatic security in production: access, auth, and data safeguards that reduce risk without slowing delivery.",
  Databases:
    "Schema design, migrations, and performance work that keep data correct and fast. Real incidents, fixes, and lessons.",
  DevOps:
    "Delivery pipelines, observability, and ops hygiene that keep teams shipping. Fewer surprises, calmer on-call.",
};

const title = "Blog - Andrew Dryga";
const description =
  (currentCategory && CATEGORY_INTRO[currentCategory]) ??
  "Posts from this category. Practical notes from shipping real systems.";
const canonical = Astro.url.href;
const consoleLine = `$ ls -la ./blog | grep ${slug}`;

function categoryHref(cat: string | null) {
  if (!cat || cat === "All") {
    return "/blog/";
  }
  const cslug = cat.toLowerCase().replace(/\s+/g, "-");
  return `/blog/category/${cslug}/`;
}

// Filter posts by selected category
const posts = allPosts
  .filter((p) => p.category === currentCategory)
  .sort((a, b) => b.publishDate.getTime() - a.publishDate.getTime());
---

<BaseLayout {title} {description} {canonical}>
  <Header slot="header" variant="header" />

  <section class="py-16 md:py-24 px-4">
    <div class="max-w-6xl mx-auto">
      <SectionHeader
        breadcrumbs={[{ label: "Home", href: "/" }, { label: "Blog" }]}
        consoleLine={consoleLine}
        titleLeading="Blog &"
        titleAccent="Insights"
        accentColor="yellow"
        description={description}
      >
        <div class="flex flex-wrap gap-2 mt-8 md:mt-12">
          {
            categories.map((cat) => {
              const isActive = cat === currentCategory;
              return (
                <a
                  href={categoryHref(cat)}
                  aria-current={isActive ? "page" : "false"}
                  class={`px-3 py-1.5 rounded-md font-mono text-sm border transition-colors ${
                    isActive
                      ? "text-background bg-terminal-yellow border-terminal-yellow"
                      : "text-muted-foreground hover:text-terminal-yellow hover:border-terminal-yellow/60 border-border"
                  }`}
                >
                  {cat}
                </a>
              );
            })
          }
        </div>
      </SectionHeader>

      {
        posts.length > 0 ? (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
            {posts.map((post, index) => {
              const href = post.url;
              return (
                <article
                  class="group p-6 rounded-lg bg-card border border-border hover:border-terminal-yellow transition-all duration-300 shadow-card hover:shadow-glow animate-fade-in relative"
                  style={`animation-delay: ${index * 100}ms`}
                >
                  <a
                    href={href}
                    class="absolute inset-0 rounded-lg"
                    aria-label={`Read more: ${post.title}`}
                  />
                  <div class="flex h-full flex-col gap-4">
                    <div class="flex items-center justify-between">
                      <span class="px-3 py-1 rounded-full bg-terminal-yellow/10 text-terminal-yellow text-xs font-mono">
                        {post.category}
                      </span>
                      <span class="font-mono text-xs text-muted-foreground">
                        {formatPublishDate(post.publishDate)}
                      </span>
                    </div>
                    <h3 class="text-xl font-bold font-sans text-foreground transition-colors group-hover:text-terminal-yellow">
                      {post.title}
                    </h3>
                    <p class="text-muted-foreground text-sm leading-relaxed">
                      {post.description}
                    </p>
                    <span class="mt-auto inline-flex items-center gap-2 text-terminal-yellow font-mono text-sm transition-all group-hover:gap-3">
                      Read more →
                    </span>
                  </div>
                </article>
              );
            })}
          </div>
        ) : (
          <div class="text-center py-16 animate-fade-in">
            <p class="text-muted-foreground text-lg font-mono">
              No posts found for this category.
            </p>
          </div>
        )
      }
    </div>
  </section>

  <Header slot="footer" variant="footer" />
</BaseLayout>

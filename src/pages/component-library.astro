---
import BaseLayout from "@/components/BaseLayout.astro";
import Header from "@/components/Header.astro";
import ComponentLibraryIsland from "@/components/islands/ComponentLibrary";

// Page metadata
const title = "Component Library — dryga.com";
const description =
  "A comprehensive terminal-themed UI component collection. Rendered as a React island to minimize migration risk.";

// Derive canonical URL if site is configured; BaseLayout can also infer it
const site = Astro.site ?? new URL("https://dryga.com/");
const canonical = new URL("/component-library", site).toString();
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Header slot="header" />

  <section class="container mx-auto px-4 py-12 max-w-6xl">
    <div class="mb-8">
      <p class="font-mono text-terminal-green mb-2">$ components --list</p>
      <h1 class="text-4xl md:text-5xl font-bold text-foreground">Component Library</h1>
      <p class="text-muted-foreground font-mono mt-3">
        React-powered showcase mounted as an island. Imports use Astro's "@/..." aliases.
      </p>
    </div>

    <!-- React Island -->
    <div id="component-library-island" class="min-h-[40vh]">
      <ComponentLibraryIsland client:load />
    </div>

    <!-- Noscript fallback -->
    <noscript>
      <div class="mt-6 border border-border rounded-lg p-4 bg-card">
        <p class="font-mono text-sm text-muted-foreground">
          JavaScript is disabled. Enable it to view the interactive component library.
        </p>
      </div>
    </noscript>
  </section>
</BaseLayout>

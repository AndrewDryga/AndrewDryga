---
import BaseLayout from "../../components/BaseLayout.astro";
import Header from "../../components/Header.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  // Collect all unique tags from blog posts (exclude drafts in production)
  const posts = await getCollection("blog", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  );

  const tagMap = new Map<string, string>();
  for (const p of posts) {
    for (const t of p.data.tags ?? []) {
      const key = t.toLowerCase();
      if (!tagMap.has(key)) tagMap.set(key, t);
    }
  }

  return Array.from(tagMap.entries()).map(([slug, label]) => ({
    params: { tag: slug },
    props: { displayTag: label },
  }));
}

const { displayTag } = Astro.props as { displayTag: string };

const lowerTag = (Astro.params.tag ?? "").toLowerCase();

// Load and filter posts by tag (case-insensitive), newest first
const allPosts = await getCollection("blog", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);
const posts = allPosts
  .filter((p) => (p.data.tags ?? []).some((t) => t.toLowerCase() === lowerTag))
  .sort((a, b) => {
    const at = a.data.publishDate?.getTime?.() ?? 0;
    const bt = b.data.publishDate?.getTime?.() ?? 0;
    return bt - at;
  });

function formatDate(d?: Date) {
  if (!d) return "";
  return d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "2-digit" });
}

function blogTagHref(tag: string) {
  return `/blog/?tag=${encodeURIComponent(tag)}`;
}

const site = Astro.site ?? new URL("https://dryga.com/");
const canonical = new URL(`/tags/${encodeURIComponent(lowerTag)}/`, site).toString();
const title = `#${displayTag} — Andrew Dryga`;
const description = `Posts tagged #${displayTag}.`;
---

<BaseLayout {title} {description} {canonical}>
  <Header slot="header" variant="header" />

  <section class="px-4 py-10 md:py-14">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <header class="mb-8 md:mb-10">
        <div class="font-mono text-sm text-terminal-green mb-2 flex items-center gap-2">
          <span class="text-terminal-cyan">~/tags/{lowerTag}</span>
          <span class="animate-pulse">▊</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold font-sans">
          <span class="text-foreground">Tag:</span>
          <span class="text-terminal-cyan"> #{displayTag}</span>
        </h1>
        <p class="text-muted-foreground max-w-2xl mt-3">
          {posts.length} {posts.length === 1 ? "post" : "posts"} tagged with <span class="text-terminal-cyan">#{displayTag}</span>.
          <a href="/blog/" class="ml-2 underline decoration-terminal-cyan/60 hover:text-terminal-green transition-colors">View all posts →</a>
        </p>
      </header>

      <!-- Posts list -->
      <div class="space-y-6 md:space-y-8">
        {posts.length === 0 ? (
          <div class="rounded-lg border border-border bg-card/40 p-6 text-muted-foreground">
            No posts found for <span class="text-terminal-cyan font-mono">#{displayTag}</span>.{" "}
            <a href="/blog/" class="underline decoration-terminal-cyan/60 hover:text-terminal-green transition-colors">Back to blog</a>.
          </div>
        ) : (
          posts.map((post) => {
            const { title: postTitle, description: desc, publishDate, tags } = post.data;
            return (
              <article class="rounded-lg border border-border bg-card/40 shadow-card hover:shadow-glow transition-shadow">
                <a href={`/blog/${post.slug}/`} class="block p-5 md:p-6">
                  <header class="mb-2">
                    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">
                      <span class="hover:text-terminal-cyan transition-colors">{postTitle}</span>
                    </h2>
                    <div class="mt-1 font-mono text-xs text-muted-foreground">
                      {publishDate ? formatDate(publishDate) : ""}
                    </div>
                  </header>
                  {desc && <p class="text-muted-foreground">{desc}</p>}
                  {tags && tags.length > 0 && (
                    <ul class="mt-4 flex flex-wrap gap-2">
                      {tags.map((t) => (
                        <li>
                          <a
                            href={blogTagHref(t)}
                            class="inline-flex items-center font-mono text-xs px-2 py-1 rounded border border-terminal-cyan/30 text-terminal-cyan hover:border-terminal-cyan hover:bg-terminal-cyan/10 transition-colors"
                          >
                            #{t}
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </a>
              </article>
            );
          })
        )}
      </div>
    </div>
  </section>

  <Header slot="footer" variant="footer" />
</BaseLayout>

---
import BaseLayout from "../components/BaseLayout.astro";
import Header from "../components/Header.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { featuredProjects } from "../data/projects";
import Testimonials from "../components/Testimonials.astro";
import { getFeaturedTestimonials } from "../data/testimonials";
import TechStack from "../components/TechStack.astro";
import Button from "../components/ui/Button.astro";
import { loadBlogSummaries, formatPublishDate } from "../lib/blog";

const title = "Andrew Dryga - Making things work";
const description =
  "I lead engineering and bring value to the business by turning fragile systems into reliable, observable, cost-sane platforms - shipping what matters, measuring results, and cutting waste without slowing teams.";
const testimonials = await getFeaturedTestimonials();
const latestPosts = (await loadBlogSummaries()).slice(0, 3);
---

<BaseLayout {title} {description}>
  <Header slot="header" variant="header" />
  <section
    id="home"
    class="min-h-[90vh] flex items-center justify-center px-4 py-14 md:py-20"
  >
    <div class="max-w-4xl w-full">
      <div
        class="space-y-8 md:space-y-10 motion-safe:animate-fade-in animate-delay-0"
      >
        <!-- Terminal-style header -->
        <div class="font-mono text-sm text-terminal-green">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-terminal-cyan">~</span>
            <span class="animate-pulse">▊</span>
          </div>
        </div>

        <!-- Main heading -->
        <div class="space-y-4">
          <h1 class="text-5xl md:text-6xl font-bold font-sans">
            <span class="text-foreground">Andrew</span>
            <span class="text-terminal-cyan"> Dryga</span>
          </h1>
          <p class="text-2xl md:text-3xl text-muted-foreground font-mono">
            &gt; Making things work
          </p>
        </div>

        <!-- Description -->
        <p class="text-lg text-muted-foreground max-w-2xl leading-relaxed">
          I lead engineering and bring value to the business by turning fragile
          systems into reliable, observable, cost-sane platforms - shipping what
          matters, measuring results, and cutting waste without slowing teams.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row flex-wrap gap-3 sm:gap-4 pt-2">
          <Button
            href="https://github.com/andrewDryga"
            target="_blank"
            rel="noopener noreferrer"
            variant="outline"
            size="lg"
            class="w-full sm:w-auto border-terminal-cyan text-terminal-cyan bg-transparent hover:bg-terminal-cyan hover:text-background shadow-glow"
          >
            <svg
              class="h-5 w-5 shrink-0"
              viewBox="0 0 24 24"
              aria-hidden="true"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M12 2C6.477 2 2 6.58 2 12.124c0 4.48 2.865 8.274 6.839 9.617.5.096.683-.22.683-.487 0-.24-.009-.876-.014-1.719-2.782.61-3.37-1.36-3.37-1.36-.454-1.163-1.11-1.474-1.11-1.474-.907-.63.069-.617.069-.617 1.003.072 1.53 1.044 1.53 1.044.892 1.543 2.341 1.097 2.91.839.091-.655.35-1.097.636-1.35-2.221-.257-4.555-1.127-4.555-5.017 0-1.109.39-2.016 1.03-2.729-.104-.258-.447-1.293.098-2.695 0 0 .84-.27 2.75 1.04a9.33 9.33 0 0 1 2.505-.343c.85.004 1.705.116 2.505.343 1.91-1.31 2.748-1.04 2.748-1.04.546 1.402.203 2.437.1 2.695.64.713 1.028 1.62 1.028 2.728 0 3.9-2.338 4.757-4.566 5.01.36.315.68.934.68 1.883 0 1.359-.012 2.454-.012 2.786 0 .27.18.586.69.486A9.999 9.999 0 0 0 22 12.124C22 6.58 17.523 2 12 2z"
              ></path>
            </svg>
            GitHub
          </Button>

          <Button
            href="https://www.linkedin.com/in/andrew-dryga-bb382557/"
            target="_blank"
            rel="noopener noreferrer"
            variant="outline"
            size="lg"
            class="w-full sm:w-auto border-terminal-green text-terminal-green bg-transparent hover:bg-terminal-green hover:text-background"
          >
            <svg
              class="h-5 w-5 shrink-0"
              viewBox="0 0 24 24"
              aria-hidden="true"
              fill="currentColor"
            >
              <path
                d="M22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.226.792 24 1.771 24h20.451C23.2 24 24 23.226 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003zM6.954 20.452H3.719V9h3.235v11.452zM5.337 7.433a2.065 2.065 0 11.001-4.13 2.065 2.065 0 01-.001 4.13zM20.447 20.452h-3.554v-5.569c0-1.33-.027-3.044-1.855-3.044-1.855 0-2.14 1.448-2.14 2.946v5.667H9.343V9h3.414v1.561h.049c.476-.9 1.637-1.848 3.37-1.848 3.6 0 4.267 2.368 4.267 5.455v6.284z"
              ></path>
            </svg>
            LinkedIn
          </Button>

          <Button
            href="/blog"
            variant="outline"
            size="lg"
            class="w-full sm:w-auto border-terminal-yellow text-terminal-yellow bg-transparent hover:bg-terminal-yellow hover:text-background"
          >
            <svg
              class="h-5 w-5 shrink-0"
              viewBox="0 0 24 24"
              aria-hidden="true"
              fill="currentColor"
            >
              <path
                d="M6 2h9a1 1 0 0 1 .8.4l3 4a1 1 0 0 1 .2.6V20a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2zm9 2H6v16h11V7h-2a2 2 0 0 1-2-2V4zm0 0v1a1 1 0 0 0 1 1h1.5L15 4zM8 10h8v2H8v-2zm0 4h8v2H8v-2z"
              ></path>
            </svg>
            Blog
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="py-14 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div>
        <div class="motion-safe:animate-fade-in animate-delay-0">
          <p class="font-mono text-terminal-green mb-2">$ cat about.txt</p>
          <h2 class="text-3xl md:text-4xl font-bold">
            About <span class="text-terminal-green">Me</span>
          </h2>

          <div class="space-y-6 max-w-3xl mt-6 md:mt-8">
            <p class="text-lg text-muted-foreground leading-relaxed">
              I'm a multi-hat product-minded engineering leader who lives at the
              intersection of product, infrastructure, and UX. Pragmatic by
              default: I ship what matters, measure outcomes, cut waste, and
              keep systems reliably boring where they should be - without
              slowing teams.
            </p>
            <p class="text-lg text-muted-foreground leading-relaxed">
              My experience spans from being a Principal Engineer at early-stage
              startups to CTO position at established products, always with a
              focus on building the right thing, the right way, while having fun
              in the process.
            </p>
          </div>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-10 md:mt-12">
          <div
            class="group p-6 rounded-lg bg-card border-2 border-terminal-cyan/30 motion-safe:animate-fade-in animate-delay-0"
          >
            <div class="flex flex-col gap-4">
              <div class="p-3 rounded-lg bg-gradient-primary w-fit">
                <!-- Trending Up -->
                <svg
                  class="h-6 w-6 text-terminal-cyan"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                  <polyline points="17 6 23 6 23 12"></polyline>
                </svg>
              </div>
              <div class="space-y-2">
                <h3 class="font-sans text-lg font-semibold text-foreground">
                  Generated Revenue
                </h3>
                <p class="text-muted-foreground text-sm leading-relaxed">
                  Grew revenue 3× to mid-seven figures; slashed infrastructure
                  costs by $2M+/yr - both in year one.
                </p>
              </div>
            </div>
          </div>

          <div
            class="group p-6 rounded-lg bg-card border-2 border-terminal-cyan/30 motion-safe:animate-fade-in animate-delay-100"
          >
            <div class="flex flex-col gap-4">
              <div class="p-3 rounded-lg bg-gradient-primary w-fit">
                <!-- Globe / Impact -->
                <svg
                  class="h-6 w-6 text-terminal-cyan"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="12" cy="12" r="9"></circle>
                  <path d="M2.5 12h19"></path>
                  <path d="M12 3v18"></path>
                </svg>
              </div>
              <div class="space-y-2">
                <h3 class="font-sans text-lg font-semibold text-foreground">
                  Made Impact
                </h3>
                <p class="text-muted-foreground text-sm leading-relaxed">
                  Led the design and shipped Ukraine’s national e-health
                  platform used by 35M+ patients and 400K+ medical
                  professionals.
                </p>
              </div>
            </div>
          </div>

          <div
            class="group p-6 rounded-lg bg-card border-2 border-terminal-cyan/30 motion-safe:animate-fade-in animate-delay-200"
          >
            <div class="flex flex-col gap-4">
              <div class="p-3 rounded-lg bg-gradient-primary w-fit">
                <!-- Gauge / Performance -->
                <svg
                  class="h-6 w-6 text-terminal-cyan"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M5 19a9 9 0 1 1 14 0"></path>
                  <circle cx="12" cy="12" r="1.5"></circle>
                  <path d="M12 12l4-4"></path>
                </svg>
              </div>
              <div class="space-y-2">
                <h3 class="font-sans text-lg font-semibold text-foreground">
                  At Scale & Performance
                </h3>
                <p class="text-muted-foreground text-sm leading-relaxed">
                  Single-handedly operated legacy Elixir systems and
                  infrastructure with 100K+ RPS across tens of services.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section id="tech-stack" class="py-14 md:py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="mb-8 motion-safe:animate-fade-in animate-delay-0">
        <p class="font-mono text-terminal-green mb-2">$ neofetch</p>
        <h2 class="text-3xl md:text-4xl font-bold">
          Tech <span class="text-terminal-green">Stack</span>
        </h2>
      </div>
      <TechStack />
    </div>
  </section>

  <!-- Projects teaser -->
  <section id="projects" class="py-16 md:py-24 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12 animate-fade-in animate-delay-0">
        <p
          class="font-mono text-terminal-green mb-2 overflow-hidden whitespace-nowrap"
        >
          <span class="inline-block"
            >$ find ~/projects -type f -name "README.md"</span
          >
        </p>
        <h2 class="text-4xl md:text-5xl font-bold font-sans">
          Featured <span class="text-terminal-green">Projects</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {
          featuredProjects.map((project, idx) => (
            <ProjectCard project={project} index={idx} />
          ))
        }
      </div>

      <div class="text-center mt-12">
        <a
          href="/projects"
          class="inline-flex items-center justify-center font-mono border-2 border-terminal-green bg-transparent text-terminal-green hover:bg-terminal-green hover:text-background transition-all rounded-md px-5 py-3"
        >
          View All Projects
        </a>
      </div>
    </div>
  </section>

  <Testimonials testimonials={testimonials} />
  <!-- Blog teaser -->
  <section id="blog" class="py-16 md:py-24 px-4 bg-terminal-surface/30">
    <div class="max-w-6xl mx-auto">
      <div class="space-y-10 md:space-y-12 animate-fade-in animate-delay-0">
        <div class="space-y-4">
          <div class="font-mono text-terminal-yellow text-sm">
            $ ls -la ./blog
          </div>
          <h2 class="text-4xl md:text-5xl font-bold font-sans">
            Latest <span class="text-terminal-yellow">Posts</span>
          </h2>
          <p class="text-lg text-muted-foreground max-w-2xl">
            Thoughts on software engineering, distributed systems, and building
            products.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {
            latestPosts.map((post, i) => {
              const delays = [
                "animate-delay-0",
                "animate-delay-100",
                "animate-delay-200",
              ];
              return (
                <article
                  class={`group p-6 rounded-lg bg-card border border-border hover:border-terminal-yellow transition-all duration-300 shadow-card hover:shadow-glow animate-fade-in ${delays[i]} relative`}
                >
                  <a
                    href={post.url}
                    class="absolute inset-0 rounded-lg"
                    aria-label={`Read more: ${post.title}`}
                  />
                  <div class="flex h-full flex-col gap-4">
                    <div class="flex items-center justify-between">
                      <span class="px-3 py-1 rounded-full bg-terminal-yellow/10 text-terminal-yellow text-xs font-mono">
                        {post.category}
                      </span>
                      <div class="font-mono text-xs text-muted-foreground">
                        {formatPublishDate(post.publishDate)}
                      </div>
                    </div>
                    <h3 class="text-xl font-bold font-sans text-foreground transition-colors group-hover:text-terminal-yellow">
                      {post.title}
                    </h3>
                    <p class="text-muted-foreground text-sm leading-relaxed">
                      {post.description}
                    </p>
                    <span class="mt-auto inline-flex items-center gap-2 text-terminal-yellow font-mono text-sm transition-all group-hover:gap-3">
                      Read more →
                    </span>
                  </div>
                </article>
              );
            })
          }
        </div>

        <div class="flex justify-center pt-8">
          <a
            href="/blog"
            class="inline-flex items-center justify-center font-mono border-2 border-terminal-yellow bg-transparent text-terminal-yellow hover:bg-terminal-yellow hover:text-background transition-all rounded-md px-5 py-3"
          >
            View All Posts
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-16 md:py-24 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12 animate-fade-in animate-delay-0">
        <p class="font-mono text-terminal-green mb-2">
          $ palantir persons find . -name "Andrew Dryga" > contacts.txt
        </p>
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          Get in <span class="text-terminal-green">Touch</span>
        </h2>
      </div>

      <div
        class="relative overflow-hidden rounded-lg bg-terminal-surface border border-terminal-cyan/30 font-mono text-sm animate-fade-in animate-delay-100"
      >
        <!-- Terminal title bar -->
        <div
          class="flex items-center gap-2 border-b border-border/40 px-4 py-3 bg-terminal-bg/40"
        >
          <span class="h-2.5 w-2.5 rounded-full bg-destructive/70"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-secondary/70"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-terminal-green/70"></span>
          <span
            class="ml-3 text-xs uppercase tracking-wide text-muted-foreground"
            >contact.sh</span
          >
        </div>

        <div id="contact-terminal" class="p-6 space-y-2">
          <div class="text-terminal-green">
            {
              "$ EMAIL=$(grep '^email:' contacts.txt | awk '{print $2}') && echo $EMAIL"
            }
          </div>
          <div class="text-foreground/90">
            <a
              href="mailto:andrew@dryga.com"
              class="text-terminal-cyan hover:text-terminal-green transition-colors"
              >andrew@dryga.com</a
            >
          </div>
          <div class="text-terminal-green">
            $ ./send-message.sh --to {'"${EMAIL}"'}
          </div>
          <div class="text-muted-foreground">
            Starting interactive message composer...
          </div>
          <div class="text-muted-foreground">
            Press Enter to confirm each step.
          </div>

          <!-- Log of completed steps + active prompt share the same space-y-2 flow -->
          <div id="terminal-log" class="empty:hidden space-y-2"></div>
          <div id="terminal-prompt" class="flex items-center gap-2 flex-wrap">
            <span class="text-terminal-yellow shrink-0">?</span>
            <span id="prompt-label" class="text-foreground shrink-0"
              >What's your name?</span
            >
            <span class="inline-flex items-center gap-0">
              <input
                id="terminal-input"
                type="text"
                autocomplete="off"
                spellcheck="false"
                class="bg-transparent text-terminal-cyan outline-none caret-transparent p-0 m-0 border-0 text-base md:text-sm"
                style="width:1ch;min-width:0"
                autofocus
              /><span
                id="terminal-cursor"
                class="animate-pulse text-terminal-cyan hidden relative -left-[1ch]"
                >▊</span
              >
            </span>
          </div>
        </div>

        <script>
          const steps = [
            { key: "name", label: "What's your name?", type: "text" },
            { key: "email", label: "Your email?", type: "email" },
            { key: "message", label: "Your message:", type: "text" },
          ];

          let current = 0;
          const data: Record<string, string> = {};

          const log = document.getElementById("terminal-log")!;
          const prompt = document.getElementById("terminal-prompt")!;
          const label = document.getElementById("prompt-label")!;
          const input = document.getElementById(
            "terminal-input",
          ) as HTMLInputElement;
          const cursor = document.getElementById("terminal-cursor")!;

          input.addEventListener("focus", () =>
            cursor.classList.remove("hidden"),
          );
          input.addEventListener("blur", () => cursor.classList.add("hidden"));

          function addLine(html: string) {
            const div = document.createElement("div");
            div.innerHTML = html;
            log.appendChild(div);
          }

          function advance() {
            const value = input.value.trim();
            if (!value) return;

            if (
              steps[current].key === "email" &&
              !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)
            ) {
              addLine(
                '<span class="text-destructive">  ✗ Please enter a valid email address.</span>',
              );
              input.value = "";
              input.style.width = "1ch";
              input.focus();
              return;
            }

            data[steps[current].key] = value;

            addLine(
              `<span class="text-terminal-green">✓</span> <span class="text-muted-foreground">${steps[current].label}</span> <span class="text-terminal-cyan">${escapeHtml(value)}</span>`,
            );

            current++;
            input.value = "";
            input.style.width = "1ch";

            if (current < steps.length) {
              label.textContent = steps[current].label;
              input.type = steps[current].type;
              input.inputMode = steps[current].type === "email" ? "email" : "text";
              input.blur();
              requestAnimationFrame(() => input.focus());
            } else {
              showConfirm();
            }
          }

          function showConfirm() {
            prompt.classList.add("hidden");

            addLine('<span class="text-muted-foreground mt-2">---</span>');
            addLine(
              `<span class="text-foreground">From:</span> <span class="text-terminal-cyan">${escapeHtml(data.name)} &lt;${escapeHtml(data.email)}&gt;</span>`,
            );
            addLine(
              `<span class="text-foreground">To:</span> <span class="text-terminal-cyan">andrew@dryga.com</span>`,
            );
            addLine(
              `<span class="text-foreground">Message:</span> <span class="text-terminal-cyan">${escapeHtml(data.message)}</span>`,
            );
            addLine('<span class="text-muted-foreground">---</span>');

            const confirmDiv = document.createElement("div");
            confirmDiv.className = "flex items-center gap-2 mt-2";
            confirmDiv.id = "confirm-prompt";
            confirmDiv.innerHTML = `
            <span class="text-terminal-yellow">?</span>
            <span class="text-foreground">Send message? (y/n)</span>
            <span class="inline-flex items-center">
              <input id="confirm-input" type="text" size="1" autocomplete="off" spellcheck="false"
                class="bg-transparent text-terminal-cyan outline-none caret-transparent w-0 py-0 pr-0 pl-px" /><span id="confirm-cursor" class="animate-pulse text-terminal-cyan hidden">▊</span>
            </span>
          `;
            log.parentElement!.appendChild(confirmDiv);

            const confirmInput = document.getElementById(
              "confirm-input",
            ) as HTMLInputElement;
            const confirmCursor = document.getElementById("confirm-cursor")!;
            confirmInput.addEventListener("focus", () =>
              confirmCursor.classList.remove("hidden"),
            );
            confirmInput.addEventListener("blur", () =>
              confirmCursor.classList.add("hidden"),
            );
            confirmInput.focus();
            confirmInput.addEventListener("input", () =>
              autoSize(confirmInput),
            );

            confirmInput.addEventListener("keydown", (e) => {
              if (e.key !== "Enter") return;
              const answer = confirmInput.value.trim().toLowerCase();
              if (answer === "y" || answer === "yes") {
                confirmDiv.remove();
                addLine(
                  `<span class="text-terminal-green">✓</span> <span class="text-muted-foreground">Send message?</span> <span class="text-terminal-cyan">yes</span>`,
                );
                sendMessage();
              } else if (answer === "n" || answer === "no") {
                confirmDiv.remove();
                addLine(
                  `<span class="text-destructive">✗</span> <span class="text-muted-foreground">Aborted.</span>`,
                );
                showRestart();
              } else {
                confirmInput.value = "";
              }
            });
          }

          async function sendMessage() {
            addLine('<span class="text-muted-foreground">Sending...</span>');

            try {
              const res = await fetch("/api/contact", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data),
              });

              if (!res.ok) {
                const err = await res
                  .json()
                  .catch(() => ({ error: "Unknown error" }));
                addLine(
                  `<span class="text-destructive">✗ ${escapeHtml((err as { error: string }).error || "Failed to send message")}</span>`,
                );
              } else {
                addLine(
                  '<span class="text-terminal-green">✓ Message sent! Andrew will get back to you soon.</span>',
                );
                return;
              }
            } catch {
              addLine(
                '<span class="text-destructive">✗ Network error. Please try again or email andrew@dryga.com directly.</span>',
              );
            }

            showRestart();
          }

          function showRestart() {
            const restartDiv = document.createElement("div");
            restartDiv.className = "mt-2";
            restartDiv.innerHTML = `
            <span class="text-muted-foreground">Press</span>
            <kbd class="px-1.5 py-0.5 rounded bg-terminal-bg/60 border border-border text-terminal-cyan text-xs">Enter</kbd>
            <span class="text-muted-foreground">to send another message</span>
          `;
            log.parentElement!.appendChild(restartDiv);

            function restart() {
              current = 0;
              Object.keys(data).forEach((k) => delete data[k]);
              log.innerHTML = "";
              restartDiv.remove();
              document.removeEventListener("keydown", restartOnEnter);
              label.textContent = steps[0].label;
              input.type = steps[0].type;
              input.value = "";
              input.style.width = "1ch";
              prompt.classList.remove("hidden");
              input.focus();
            }

            function restartOnEnter(e: KeyboardEvent) {
              if (e.key === "Enter") {
                e.preventDefault();
                restart();
              }
            }

            restartDiv.addEventListener("click", restart);
            document.addEventListener("keydown", restartOnEnter);
          }

          function escapeHtml(str: string) {
            const el = document.createElement("span");
            el.textContent = str;
            return el.innerHTML;
          }

          function autoSize(el: HTMLInputElement) {
            el.style.width =
              (el.value.length === 0 ? 1 : el.value.length + 1) + "ch";
          }

          input.addEventListener("keydown", (e) => {
            if (e.key === "Enter") {
              e.preventDefault();
              advance();
            }
          });

          input.addEventListener("input", () => autoSize(input));

          document
            .getElementById("contact-terminal")!
            .addEventListener("click", () => {
              const confirmInput = document.getElementById(
                "confirm-input",
              ) as HTMLInputElement | null;
              if (confirmInput) {
                confirmInput.focus();
              } else if (!prompt.classList.contains("hidden")) {
                input.focus();
              }
            });
        </script>
      </div>


---
import { getCollection } from "astro:content";
import BaseLayout from "../../components/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { allProjects } from "../../data/projects";

// Helper to normalize strings for matching
function norm(s: string | undefined | null): string {
  return (s ?? "").toLowerCase();
}

export async function getStaticPaths() {
  // Get all projects from projects.ts
  const paths = allProjects.map((project) => ({
    params: { id: project.id },
    props: { projectId: project.id },
  }));

  return paths;
}

const { projectId } = Astro.props;

// Get project metadata from projects.ts
const project = allProjects.find((p) => p.id === projectId);

if (!project) {
  return Astro.redirect("/404");
}

// Try to get markdown content if it exists
let entry = null;
let Content = null;

try {
  const allProjectContent = await getCollection("projects");
  entry = allProjectContent.find(
    (e) => e.data.projectId === projectId && !e.data.draft,
  );
  if (entry) {
    const rendered = await entry.render();
    Content = rendered.Content;
  }
} catch (e) {
  // No markdown content exists, that's fine
}

const title = entry?.data?.title || project.name;
const description = project.description;

const site = Astro.site ?? new URL("https://dryga.com/");
const canonical = new URL(`/projects/${projectId}/`, site).toString();

// Find related blog posts (explicit only via relatedProjects field)
const allBlogPosts = await getCollection("blog", ({ data }: { data: any }) =>
  import.meta.env.PROD ? !data.draft : true,
);

const relatedPosts = allBlogPosts.filter((post: any) => {
  const relatedProjects = post.data.relatedProjects ?? [];
  return relatedProjects.some(
    (relId: string) =>
      norm(relId) === norm(project.id) || norm(relId) === norm(project.name),
  );
});

// JSON-LD: BreadcrumbList
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: new URL("/", site).toString(),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Projects",
      item: new URL("/projects/", site).toString(),
    },
    { "@type": "ListItem", position: 3, name: project.name, item: canonical },
  ],
};

// JSON-LD: Project/CreativeWork
const projectLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: project.name,
  description: project.description,
  author: {
    "@type": "Person",
    name: "Andrew Dryga",
    url: "https://dryga.com/about",
  },
  url: canonical,
  keywords: project.tech.join(", "),
};
---

<BaseLayout {title} {description}>
  <Header slot="header" variant="header" />

  <article class="max-w-4xl mx-auto px-4 py-12 md:py-20">
    <!-- Header -->
    <header class="mb-12 space-y-6">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "Projects", href: "/projects/" },
          { label: project.name },
        ]}
        class="mb-4"
      />
      <div class="space-y-2">
        <div class="flex flex-wrap gap-2 text-sm">
          {
            project.categories.map((category) => (
              <span class="px-3 py-1 rounded-full bg-terminal-cyan/10 text-terminal-cyan font-mono">
                {category}
              </span>
            ))
          }
          {
            project.period && (
              <span class="px-3 py-1 rounded-full bg-terminal-green/10 text-terminal-green font-mono">
                {project.period}
              </span>
            )
          }
        </div>
        <h1 class="text-4xl md:text-5xl font-bold">
          {title}
        </h1>
      </div>

      <!-- Tech Stack -->
      {
        project.tech && project.tech.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {project.tech.map((tech) => (
              <span class="px-3 py-1 rounded bg-terminal-surface text-sm font-mono text-foreground/80">
                {tech}
              </span>
            ))}
          </div>
        )
      }
    </header>

    <!-- Content -->
    {
      Content ? (
        <div
          class="prose prose-lg prose-invert max-w-none
          prose-headings:font-bold prose-headings:text-foreground
          prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6
          prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-4
          prose-p:text-muted-foreground prose-p:leading-relaxed
          prose-a:text-terminal-cyan prose-a:no-underline hover:prose-a:underline
          prose-strong:text-foreground prose-strong:font-semibold
          prose-ul:text-muted-foreground prose-ul:leading-relaxed
          prose-li:my-2
          prose-code:text-terminal-green prose-code:bg-terminal-surface prose-code:px-1 prose-code:py-0.5 prose-code:rounded
          prose-pre:bg-terminal-surface prose-pre:border prose-pre:border-border"
        >
          <Content />
        </div>
      ) : (
        <div class="space-y-8">
          <div>
            <p class="text-xl text-muted-foreground leading-relaxed mb-6">
              {description}
            </p>
            {project.impact && project.impact.length > 0 && (
              <div class="space-y-4">
                <h2 class="text-2xl font-bold text-foreground">Impact</h2>
                <ul class="space-y-3">
                  {project.impact.map((item) => (
                    <li class="flex items-start gap-3 text-lg leading-relaxed text-muted-foreground">
                      <span class="mt-2 h-2 w-2 flex-shrink-0 rounded-full bg-terminal-green" />
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      )
    }

    <!-- Links -->
    {
      project.links && project.links.length > 0 && (
        <div class="flex flex-wrap gap-3 mt-8">
          {project.links.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-card border border-border hover:border-terminal-cyan transition-all duration-300 text-sm font-mono"
            >
              {link.type === "github" && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.477 2 2 6.58 2 12.124c0 4.48 2.865 8.274 6.839 9.617.5.096.683-.22.683-.487 0-.24-.009-.876-.014-1.719-2.782.61-3.37-1.36-3.37-1.36-.454-1.163-1.11-1.474-1.11-1.474-.907-.63.069-.617.069-.617 1.003.072 1.53 1.044 1.53 1.044.892 1.543 2.341 1.097 2.91.839.091-.655.35-1.097.636-1.35-2.221-.257-4.555-1.127-4.555-5.017 0-1.109.39-2.016 1.03-2.729-.104-.258-.447-1.293.098-2.695 0 0 .84-.27 2.75 1.04a9.33 9.33 0 0 1 2.505-.343c.85.004 1.705.116 2.505.343 1.91-1.31 2.748-1.04 2.748-1.04.546 1.402.203 2.437.1 2.695.64.713 1.028 1.62 1.028 2.728 0 3.9-2.338 4.757-4.566 5.01.36.315.68.934.68 1.883 0 1.359-.012 2.454-.012 2.786 0 .27.18.586.69.486A9.999 9.999 0 0 0 22 12.124C22 6.58 17.523 2 12 2z" />
                </svg>
              )}
              {link.label}
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
            </a>
          ))}
        </div>
      )
    }

    <!-- Related Blog Posts -->
    {
      relatedPosts.length > 0 && (
        <section class="mt-12">
          <h2 class="text-2xl md:text-3xl font-bold mb-6 flex items-center gap-2">
            Related <span class="text-terminal-yellow">Articles</span>
          </h2>
          <div class="grid md:grid-cols-1 lg:grid-cols-2 gap-6">
            {relatedPosts.map((post: any, idx: number) => {
              const publishDate = post.data.publishDate
                ? new Date(post.data.publishDate).toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "2-digit",
                  })
                : "";

              return (
                <article class="group p-6 rounded-lg bg-card border border-border hover:border-terminal-yellow transition-all duration-300 shadow-card hover:shadow-glow relative">
                  <a
                    href={`/blog/${post.slug}/`}
                    class="absolute inset-0 rounded-lg"
                    aria-label={`Read more: ${post.data.title}`}
                  />
                  <div class="flex h-full flex-col gap-4">
                    <div class="flex items-center justify-between">
                      {post.data.category && (
                        <span class="px-3 py-1 rounded-full bg-terminal-yellow/10 text-terminal-yellow text-xs font-mono">
                          {post.data.category}
                        </span>
                      )}
                      {publishDate && (
                        <div class="font-mono text-xs text-muted-foreground">
                          {publishDate}
                        </div>
                      )}
                    </div>
                    <h3 class="text-xl font-bold font-sans text-foreground transition-colors group-hover:text-terminal-yellow">
                      {post.data.title}
                    </h3>
                    <p class="text-muted-foreground text-sm leading-relaxed line-clamp-3">
                      {post.data.description}
                    </p>
                    <span class="mt-auto inline-flex items-center gap-2 text-terminal-yellow font-mono text-sm transition-all group-hover:gap-3">
                      Read more →
                    </span>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      )
    }
  </article>

  <Header slot="footer" variant="footer" />

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(projectLd)}
  />
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbLd)}
  />
</BaseLayout>

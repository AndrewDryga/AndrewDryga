---
import BaseLayout from "../../../components/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import SectionHeader from "../../../components/SectionHeader.astro";
import ProjectCard from "../../../components/ProjectCard.astro";
import {
  allProjects as allProjectsData,
  projectCategories as exportedProjectCategories,
} from "../../../data/projects";

// Slug helpers
function toSlug(s: string) {
  return s.toLowerCase().replace(/\s+/g, "-");
}
function fromSlug(slug: string, pool: string[]) {
  return pool.find((c) => toSlug(c) === slug) ?? null;
}

// Resolve project lists and categories at runtime
const computedUnique = Array.from(
  new Set(
    (allProjectsData || []).flatMap((p) =>
      Array.isArray(p.categories) ? p.categories : [],
    ),
  ),
).sort();

const CATEGORY_META = {
  AdTech: {
    description:
      "Advertising platforms, lead generation, and sales automation — high-traffic systems that drive revenue.",
    accent: "cyan" as const,
  },
  FinTech: {
    description:
      "Payment systems, P2P lending, eWallets, and financial platforms built for regulated workflows at scale.",
    accent: "yellow" as const,
  },
  HealthTech: {
    description:
      "National-scale healthcare systems — EMR, e-prescriptions, reimbursements, and patient data platforms.",
    accent: "green" as const,
  },
  LegalTech: {
    description:
      "Contract management and legal workflow automation for B2B clients.",
    accent: "cyan" as const,
  },
  Security: {
    description:
      "Zero-trust access, hardened services, and practical controls that reduce risk without blocking delivery.",
    accent: "cyan" as const,
  },
  "Open Source": {
    description:
      "Libraries, tools, and frameworks contributed to the Elixir and other ecosystems.",
    accent: "green" as const,
  },
  Other: {
    description:
      "Side projects, experiments, and advisory work across various domains.",
    accent: "yellow" as const,
  },
} satisfies Record<
  string,
  {
    description: string;
    accent: "green" | "yellow" | "cyan";
  }
>;

const projectCategories = Array.isArray(exportedProjectCategories)
  ? exportedProjectCategories
  : ["All", ...computedUnique];

// Generate static paths for each category (except "All")
export async function getStaticPaths() {
  const categories = Array.isArray(exportedProjectCategories)
    ? exportedProjectCategories
    : ["All", ...computedUnique];
  const slugs = categories
    .filter((c) => c !== "All")
    .map((cat) => cat.toLowerCase().replace(/\s+/g, "-"));

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

// Resolve category name from slug
const currentCategory = fromSlug(slug!, projectCategories);

if (!currentCategory) {
  // Unknown category -> go back to projects index
  return Astro.redirect("/projects/");
}

// If someone hits `/projects/category/all`, normalize to index
if (currentCategory === "All") {
  return Astro.redirect("/projects/");
}

const meta = CATEGORY_META[currentCategory as keyof typeof CATEGORY_META] ?? {
  description: `Projects focused on ${currentCategory.toLowerCase()} initiatives and results.`,
  accent: "green" as const,
};

const title = `Projects — ${currentCategory} — Andrew Dryga`;
const description = meta.description;
const canonical = Astro.url.href;
const consoleLine = `$ ls -la ~/projects/ | grep category:${currentCategory.toLowerCase()}`;

// Filter projects by category
const projectsFiltered = (allProjectsData || []).filter(
  (p) => Array.isArray(p.categories) && p.categories.includes(currentCategory),
);

function categoryHref(cat: string | null) {
  if (!cat || cat === "All") {
    return "/projects/";
  }
  const cslug = toSlug(cat);
  return `/projects/category/${cslug}/`;
}
---

<BaseLayout {title} {description} {canonical}>
  <Header slot="header" variant="header" />

  <section class="py-16 md:py-24 px-4">
    <div class="max-w-6xl mx-auto">
      <SectionHeader
        breadcrumbs={[
          { label: "Home", href: "/" },
          { label: "Projects", href: "/projects" },
        ]}
        consoleLine={consoleLine}
        titleLeading="Projects:"
        titleAccent={currentCategory}
        accentColor={meta.accent}
        description={meta.description}
      >
        <div class="flex flex-wrap gap-2 mt-8 md:mt-12">
          {
            projectCategories.map((cat) => {
              const isActive = cat === currentCategory;
              return (
                <a
                  href={categoryHref(cat)}
                  aria-current={isActive ? "page" : "false"}
                  class={`px-3 py-1.5 rounded-md font-mono text-sm border transition-colors ${
                    isActive
                      ? "text-background bg-terminal-green border-terminal-green"
                      : "text-muted-foreground hover:text-terminal-green hover:border-terminal-green/60 border-border"
                  }`}
                >
                  {cat}
                </a>
              );
            })
          }
        </div>
      </SectionHeader>

      {
        projectsFiltered.length > 0 ? (
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            {projectsFiltered.map((project, idx) => (
              <ProjectCard project={project} index={idx} />
            ))}
          </div>
        ) : (
          <div class="text-center py-16 animate-fade-in">
            <p class="text-lg text-muted-foreground">
              No projects found for this category.
            </p>
          </div>
        )
      }
    </div>
  </section>

  <Header slot="footer" variant="footer" />
</BaseLayout>

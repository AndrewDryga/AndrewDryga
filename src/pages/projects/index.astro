---
import BaseLayout from "../../components/BaseLayout.astro";
import Header from "../../components/Header.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { allProjects, projectCategories } from "../../data/projects";

const title = "Projects — Andrew Dryga";
const description =
  "Selected work—from national platforms to open-source. Focused on clear outcomes, reliability, and simple designs that scale.";
const canonical = Astro.url.href;
const selectedCategory = "All";

const PAGE_SIZE = 6;

// Read query param for pagination
const url = Astro.url;
const pathPageMatch = url.pathname.match(/\/projects\/page\/(\d+)\/?$/);
const pathPage = pathPageMatch ? Number.parseInt(pathPageMatch[1]) : NaN;
const qpPage = Number.parseInt(url.searchParams.get("page") ?? "");
const currentPageRaw = Number.isFinite(pathPage) ? pathPage : qpPage;
const currentPage =
  Number.isFinite(currentPageRaw) && currentPageRaw > 0 ? currentPageRaw : 1;

// Manual pagination
const totalPages = Math.max(1, Math.ceil(allProjects.length / PAGE_SIZE));
const safePage = Math.min(Math.max(1, currentPage), totalPages);
const start = (safePage - 1) * PAGE_SIZE;
const pageProjects = allProjects.slice(start, start + PAGE_SIZE);

function pageHref(page: number) {
  const params = new URLSearchParams(url.searchParams);
  // Use path-based pagination; strip any lingering ?page
  params.delete("page");
  const base = page <= 1 ? "/projects/" : `/projects/page/${page}/`;
  const qs = params.toString();
  return qs ? `${base}?${qs}` : base;
}

function categoryHref(cat: string) {
  if (!cat || cat === "All") return "/projects/";
  const slug = cat.toLowerCase().replace(/\s+/g, "-");
  return `/projects/category/${slug}/`;
}
---

<BaseLayout {title} {description} {canonical}>
  <Header slot="header" variant="header" />

  <section class="py-16 md:py-24 px-4">
    <div class="max-w-6xl mx-auto">
      <SectionHeader
        breadcrumbs={[{ label: "Home", href: "/" }, { label: "Projects" }]}
        consoleLine="$ ls -la ~/projects/"
        titleLeading="All"
        titleAccent="Projects"
        accentColor="green"
        description="Selected work—from national platforms to open-source. Focused on clear outcomes, reliability, and simple designs that scale."
      >
        <div class="flex flex-wrap gap-2 mt-8 md:mt-12">
          {
            ["All", ...projectCategories.filter((c) => c !== "All")].map(
              (cat) => {
                const isActive = cat === selectedCategory;
                return (
                  <a
                    href={categoryHref(cat)}
                    aria-current={isActive ? "page" : "false"}
                    class={`px-3 py-1.5 rounded-md font-mono text-sm border transition-colors ${
                      isActive
                        ? "text-background bg-terminal-green border-terminal-green"
                        : "text-muted-foreground hover:text-terminal-green hover:border-terminal-green/60 border-border"
                    }`}
                  >
                    {cat}
                  </a>
                );
              },
            )
          }
        </div>
      </SectionHeader>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {
          pageProjects.map((project, idx) => (
            <ProjectCard project={project} index={idx} />
          ))
        }
      </div>

      {
        totalPages > 1 && (
          <nav
            class="mt-2 md:mt-4 flex items-center justify-center gap-2"
            aria-label="Pagination"
          >
            <div>
              {safePage > 1 ? (
                <a
                  href={pageHref(safePage - 1)}
                  class="inline-flex items-center font-mono text-sm px-3 py-2 rounded-md border border-border text-muted-foreground hover:text-terminal-green hover:border-terminal-green/60 transition-colors"
                  rel="prev"
                >
                  ← Prev
                </a>
              ) : (
                <span class="inline-flex items-center font-mono text-sm px-3 py-2 rounded-md border border-border/40 text-muted-foreground/50 cursor-not-allowed select-none">
                  ← Prev
                </span>
              )}
            </div>

            <ul class="flex items-center gap-1">
              {Array.from({ length: totalPages }).map((_, i) => {
                const pageNum = i + 1;
                const isCurrent = pageNum === safePage;
                return (
                  <li>
                    <a
                      href={pageHref(pageNum)}
                      aria-current={isCurrent ? "page" : "false"}
                      class={`inline-flex items-center justify-center w-9 h-9 rounded-md border font-mono text-sm transition-colors ${
                        isCurrent
                          ? "border-terminal-green text-background bg-terminal-green"
                          : "border-border text-muted-foreground hover:text-terminal-green hover:border-terminal-green/60"
                      }`}
                    >
                      {pageNum}
                    </a>
                  </li>
                );
              })}
            </ul>

            <div>
              {safePage < totalPages ? (
                <a
                  href={pageHref(safePage + 1)}
                  class="inline-flex items-center font-mono text-sm px-3 py-2 rounded-md border border-border text-muted-foreground hover:text-terminal-green hover:border-terminal-green/60 transition-colors"
                  rel="next"
                >
                  Next →
                </a>
              ) : (
                <span class="inline-flex items-center font-mono text-sm px-3 py-2 rounded-md border border-border/40 text-muted-foreground/50 cursor-not-allowed select-none">
                  Next →
                </span>
              )}
            </div>
          </nav>
        )
      }
    </div>
  </section>

  <Header slot="footer" variant="footer" />
</BaseLayout>

---
export interface NavLink {
  name: string;
  href: string;
  external?: boolean;
}

export interface Props {
  links?: NavLink[];
  class?: string;
}

const { links = [], class: className = "" } = Astro.props;
---

<div class={["md:hidden", className].filter(Boolean).join(" ")}>
  <button
    type="button"
    id="mobile-nav-toggle"
    class="flex items-center justify-center rounded-md p-2 text-muted-foreground transition-colors hover:text-terminal-cyan focus:outline-none"
    aria-expanded="false"
    aria-label="Toggle navigation"
  >
    <svg
      id="mobile-nav-icon-open"
      class="h-5 w-5"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <line x1="3" x2="21" y1="6" y2="6"></line>
      <line x1="3" x2="21" y1="12" y2="12"></line>
      <line x1="3" x2="21" y1="18" y2="18"></line>
    </svg>
    <svg
      id="mobile-nav-icon-close"
      class="h-5 w-5"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      style="display:none"
    >
      <line x1="18" x2="6" y1="6" y2="18"></line>
      <line x1="6" x2="18" y1="6" y2="18"></line>
    </svg>
  </button>
</div>

<div id="mobile-nav-panel" style="display:none;position:fixed;top:65px;left:0;width:100%;height:calc(100vh - 65px);height:calc(100dvh - 65px);z-index:60;background:hsl(220,15%,8%);border-top:1px solid hsl(220,15%,18%);overflow-y:auto;font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace">
  <div style="padding:24px 24px 16px;font-size:13px;color:hsl(180,20%,50%,0.5)">
    <span style="color:hsl(142,70%,60%)">$</span> ls ~/
  </div>
  <div style="padding:0 16px">
    {links.map((link) => (
      <a
        href={link.href}
        style="display:flex;align-items:center;gap:6px;padding:14px 12px;font-size:15px;color:hsl(34,211,238,0.9);text-decoration:none"
        {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
      >
        <span style="color:hsl(142,70%,60%);font-size:13px">›</span>
        <span>{link.name.toLowerCase()}/</span>
      </a>
    ))}
  </div>
  <div style="padding:8px 28px;font-size:12px;color:hsl(180,20%,50%,0.35)">
    {links.length} directories
  </div>
</div>

<script is:inline>
(function() {
  var toggle = document.getElementById("mobile-nav-toggle");
  var panel = document.getElementById("mobile-nav-panel");
  var iconOpen = document.getElementById("mobile-nav-icon-open");
  var iconClose = document.getElementById("mobile-nav-icon-close");
  if (!toggle || !panel) return;

  function open() {
    panel.style.display = "block";
    toggle.setAttribute("aria-expanded", "true");
    if (iconOpen) iconOpen.style.display = "none";
    if (iconClose) iconClose.style.display = "";
    document.body.style.overflow = "hidden";
  }

  function close() {
    panel.style.display = "none";
    toggle.setAttribute("aria-expanded", "false");
    if (iconOpen) iconOpen.style.display = "";
    if (iconClose) iconClose.style.display = "none";
    document.body.style.overflow = "";
  }

  function isOpen() {
    return panel.style.display !== "none";
  }

  toggle.addEventListener("click", function() {
    if (isOpen()) close(); else open();
  });

  panel.querySelectorAll("a").forEach(function(a) {
    a.addEventListener("click", close);
  });

  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape" && isOpen()) close();
  });
})();
</script>

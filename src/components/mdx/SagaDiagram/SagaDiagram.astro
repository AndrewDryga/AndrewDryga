---
export interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<div
  class="saga-diagram border border-border rounded-lg bg-terminal-surface p-4 md:p-6 overflow-x-auto font-mono text-xs"
>
  {
    title && (
      <div class="text-muted-foreground text-[11px] uppercase tracking-wider mb-4">
        {title}
      </div>
    )
  }
  <div
    class="inline-grid items-center"
    style="grid-template-rows: auto auto auto; grid-auto-flow: column; grid-auto-columns: auto;"
  >
    <slot />
  </div>
</div>

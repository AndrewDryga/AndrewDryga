---
interface Props {
  label: string;
  type?: "request" | "response" | "async" | "error" | "success";
  from?: number;
  to?: number;
  class?: string;
}

const {
  label,
  type = "request",
  from,
  to,
  class: className = "",
} = Astro.props as Props;

const styles: Record<
  NonNullable<Props["type"]>,
  {
    line: string;
    arrowRight: string;
    arrowLeft: string;
    text: string;
    borderColor: string;
  }
> = {
  request: {
    line: "border-primary",
    arrowRight: "border-l-primary",
    arrowLeft: "border-r-primary",
    text: "text-foreground border-border",
    borderColor: "border-primary",
  },
  response: {
    line: "border-dashed border-secondary",
    arrowRight: "border-l-secondary",
    arrowLeft: "border-r-secondary",
    text: "text-secondary border-secondary",
    borderColor: "border-secondary border-dashed",
  },
  async: {
    line: "border-dashed border-accent",
    arrowRight: "border-l-accent",
    arrowLeft: "border-r-accent",
    text: "text-accent border-accent",
    borderColor: "border-accent border-dashed",
  },
  error: {
    line: "border-dashed border-destructive",
    arrowRight: "border-l-destructive",
    arrowLeft: "border-r-destructive",
    text: "text-destructive border-destructive",
    borderColor: "border-destructive border-dashed",
  },
  success: {
    line: "border-dashed border-terminal-green",
    arrowRight: "border-l-terminal-green",
    arrowLeft: "border-r-terminal-green",
    text: "text-terminal-green border-terminal-green",
    borderColor: "border-terminal-green border-dashed",
  },
};

const style = styles[type];

// Default from/to indices based on message type
const defaultFrom = type === "response" || type === "error" || type === "success" ? 1 : 0;
const defaultTo = type === "response" || type === "error" || type === "success" ? 0 : 1;

const fromIndex = from ?? defaultFrom;
const toIndex = to ?? defaultTo;

const isSelfCall = fromIndex === toIndex;
---

{isSelfCall ? (
  <!-- Self-call / loop -->
  <div
    class={`sd-row sd-message sd-self-call relative h-20 ${className}`.trim()}
    data-from={fromIndex}
    data-to={toIndex}
  >
    <div class="sd-message-arrow absolute top-1/2 -translate-y-1/2">
      <!-- Will be positioned by JS -->
      <div class={`sd-self-call-box border-2 rounded-r-lg rounded-l-none border-l-0 w-16 h-12 ${style.borderColor}`}>
        <!-- Arrow pointing back to lifeline at bottom -->
        <div class={`sd-arrow-head absolute left-0 bottom-0 translate-y-[calc(50%-1px)] w-0 h-0 border-t-[6px] border-t-transparent border-b-[6px] border-b-transparent border-r-[10px] ${style.arrowLeft}`}></div>
      </div>
    </div>
    <div class="sd-message-label absolute top-1/2 -translate-y-1/2 pointer-events-none z-10">
      <div class={`inline-block bg-terminal-surface px-2 py-1 text-[10px] border rounded whitespace-nowrap ${style.text}`}>
        {label}
      </div>
    </div>
  </div>
) : (
  <!-- Regular message between participants -->
  <div
    class={`sd-row sd-message relative h-16 ${className}`.trim()}
    data-from={fromIndex}
    data-to={toIndex}
  >
    <div class="sd-message-arrow absolute top-1/2 -translate-y-1/2 flex items-center">
      <div class={`w-full border-t-2 relative ${style.line}`}>
        <div class={`sd-arrow-head ${style.arrowRight} ${style.arrowLeft}`}></div>
      </div>
    </div>
    <div class="sd-message-label absolute -top-1 z-10 pointer-events-none">
      <div class={`inline-block bg-terminal-surface px-2 py-1 text-[10px] border rounded whitespace-nowrap ${style.text}`}>
        {label}
      </div>
    </div>
  </div>
)}

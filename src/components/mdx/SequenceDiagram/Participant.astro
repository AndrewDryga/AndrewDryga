---
interface Props {
  name: string;
  color?: "primary" | "accent" | "secondary" | "terminal-green";
  class?: string;
}

const { name, color = "primary", class: className = "" } = Astro.props as Props;

const colorMap: Record<NonNullable<Props["color"]>, string> = {
  primary: "bg-primary/20 text-primary border-primary",
  accent: "bg-accent/20 text-accent border-accent",
  secondary: "bg-secondary/20 text-secondary border-secondary",
  "terminal-green":
    "bg-terminal-green/20 text-terminal-green border-terminal-green",
};
---

<div
  class={`sd-participant absolute top-0 bottom-0 -translate-x-1/2 z-10 flex flex-col ${className}`.trim()}
>
  <div
    class={`inline-block px-2 py-1.5 sm:px-3 sm:py-2 border-2 rounded font-bold flex-shrink-0 text-[10px] sm:text-xs ${colorMap[color]}`}
  >
    {name}
  </div>
  <div class="pointer-events-none flex-1 relative">
    <div
      class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-px border-l border-dashed border-terminal-cyan/40"
    >
    </div>
  </div>
</div>

---
const { class: className = "" } = Astro.props;
---

<div
  class={`sequence-diagram relative border border-border rounded-lg p-3 pb-8 sm:p-6 sm:pb-10 bg-terminal-surface font-mono text-xs overflow-x-auto ${className}`.trim()}
>
  <div class="relative space-y-4">
    <slot />
  </div>
</div>

<style is:global>
  /*
    Inside CombinedFragments (.sd-frag) the content area is narrower due to
    padding + border.  Elements that must stay aligned with the lifelines
    (.sd-row) use negative margins to extend back to the outer width.
    Each nesting level adds 1rem padding + 1px border = 17px per side.
  */
  .sd-frag .sd-row {
    margin-left: calc(-1rem - 1px);
    margin-right: calc(-1rem - 1px);
  }
  .sd-frag .sd-frag .sd-row {
    margin-left: calc(-2rem - 2px);
    margin-right: calc(-2rem - 2px);
  }
  .sd-frag .sd-frag .sd-frag .sd-row {
    margin-left: calc(-3rem - 3px);
    margin-right: calc(-3rem - 3px);
  }
  .sd-frag .sd-frag .sd-frag .sd-frag .sd-row {
    margin-left: calc(-4rem - 4px);
    margin-right: calc(-4rem - 4px);
  }
  .sd-frag .sd-frag .sd-frag .sd-frag .sd-frag .sd-row {
    margin-left: calc(-5rem - 5px);
    margin-right: calc(-5rem - 5px);
  }

  /*
    When an .sd-row sits between .sd-frag ancestors (e.g. ActivationBox inside
    a fragment containing another fragment), the .sd-row already stretches to
    the outermost width.  Fragments inside it start a new nesting context, so
    the margin correction must restart from 1.  These selectors are more
    specific (extra .sd-row ancestor) and override the rules above.
  */
  .sd-row .sd-frag .sd-row {
    margin-left: calc(-1rem - 1px);
    margin-right: calc(-1rem - 1px);
  }
  .sd-row .sd-frag .sd-frag .sd-row {
    margin-left: calc(-2rem - 2px);
    margin-right: calc(-2rem - 2px);
  }
  .sd-row .sd-frag .sd-frag .sd-frag .sd-row {
    margin-left: calc(-3rem - 3px);
    margin-right: calc(-3rem - 3px);
  }
  .sd-row .sd-frag .sd-frag .sd-frag .sd-frag .sd-row {
    margin-left: calc(-4rem - 4px);
    margin-right: calc(-4rem - 4px);
  }

  /*
    Fragment label badges use absolute -top-3 (~12px above the border).
    Ensure enough margin so badges don't overlap previous content.
    Use !important to override space-y-* utilities which have higher specificity.
  */
  .sd-frag + .sd-frag {
    margin-top: 1.25rem !important;
  }
  .sd-row + .sd-frag {
    margin-top: 1.25rem !important;
  }

  /* Notes directly after fragments need breathing room too */
  .sd-frag + .sd-row {
    margin-top: 0.75rem !important;
  }

  /* Label text: allow wrapping when JS sets max-width */
  .sd-label-text {
    word-break: break-word;
  }
</style>

<script>
  // Set up participant tracking on the client side
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".sequence-diagram").forEach((diagram) => {
      const participants = Array.from(
        diagram.querySelectorAll(".sd-participant"),
      );
      const count = participants.length;

      if (count === 0) return;

      // Calculate positions automatically
      const margin = 10; // 10% margin on each side
      const availableSpace = 100 - 2 * margin;
      const spacing = count > 1 ? availableSpace / (count - 1) : 0;

      participants.forEach((participant, index) => {
        const position = count === 1 ? 50 : margin + spacing * index;
        (participant as HTMLElement).style.left = `${position}%`;
        (participant as HTMLElement).setAttribute(
          "data-position",
          position.toString(),
        );
        (participant as HTMLElement).setAttribute(
          "data-index",
          index.toString(),
        );
      });

      // Update activation boxes based on participant positions
      const activationBoxes = diagram.querySelectorAll(".sd-activation-box");
      activationBoxes.forEach((box) => {
        const participantIndex = parseInt(
          (box as HTMLElement).getAttribute("data-participant") || "0",
        );

        if (participantIndex < 0 || participantIndex >= count) return;

        const participant = participants[participantIndex] as HTMLElement;
        const position = parseFloat(
          participant.getAttribute("data-position") || "0",
        );

        const bar = box.querySelector(".sd-activation-bar") as HTMLElement;
        if (bar) {
          bar.style.left = `${position}%`;
        }
      });

      // Update standalone self-calls based on participant positions
      const standaloneSelfCalls = diagram.querySelectorAll(
        ".sd-self-call-standalone",
      );
      standaloneSelfCalls.forEach((selfCall) => {
        const participantIndex = parseInt(
          (selfCall as HTMLElement).getAttribute("data-participant") || "0",
        );

        if (participantIndex < 0 || participantIndex >= count) return;

        const participant = participants[participantIndex] as HTMLElement;
        const position = parseFloat(
          participant.getAttribute("data-position") || "0",
        );

        const container = selfCall.querySelector(
          ".sd-self-call-box-container",
        ) as HTMLElement;
        if (container) {
          container.style.left = `${position}%`;
        }

        const label = selfCall.querySelector(
          ".sd-self-call-label",
        ) as HTMLElement;
        if (label) {
          label.style.left = `${position}%`;
          label.style.paddingLeft = "2rem";
        }
      });

      // Update message arrows and labels based on participant positions
      const messages = diagram.querySelectorAll(".sd-message");
      messages.forEach((message) => {
        const fromIndex = parseInt(
          (message as HTMLElement).getAttribute("data-from") || "0",
        );
        const toIndex = parseInt(
          (message as HTMLElement).getAttribute("data-to") || "1",
        );

        if (
          fromIndex < 0 ||
          toIndex < 0 ||
          fromIndex >= count ||
          toIndex >= count
        )
          return;

        const fromParticipant = participants[fromIndex] as HTMLElement;
        const toParticipant = participants[toIndex] as HTMLElement;

        const fromPos = parseFloat(
          fromParticipant.getAttribute("data-position") || "0",
        );
        const toPos = parseFloat(
          toParticipant.getAttribute("data-position") || "0",
        );

        // Handle self-calls
        if (fromIndex === toIndex) {
          const arrow = message.querySelector(
            ".sd-message-arrow",
          ) as HTMLElement;
          const label = message.querySelector(
            ".sd-message-label",
          ) as HTMLElement;

          if (arrow) {
            // Position the loop box starting at the lifeline
            arrow.style.left = `${fromPos}%`;
          }

          if (label) {
            // Position label centered over the loop box
            label.style.left = `${fromPos}%`;
            label.style.paddingLeft = "2rem"; // Offset to center over the box
          }
        } else {
          // Regular message between different participants
          const start = Math.min(fromPos, toPos);
          const width = Math.abs(toPos - fromPos);
          const midpoint = start + width / 2;

          const arrow = message.querySelector(
            ".sd-message-arrow",
          ) as HTMLElement;
          if (arrow) {
            arrow.style.left = `${start}%`;
            arrow.style.width = `${width}%`;

            // Update arrow direction - preserve color classes
            const arrowHead = arrow.querySelector(".sd-arrow-head");
            if (arrowHead) {
              const existingClasses = arrowHead.className
                .split(" ")
                .filter(
                  (c) => c.startsWith("border-l-") || c.startsWith("border-r-"),
                )
                .join(" ");

              arrowHead.className =
                toPos > fromPos
                  ? `sd-arrow-head sd-arrow-right absolute right-0 top-1/2 w-0 h-0 border-t-[6px] border-t-transparent border-b-[6px] border-b-transparent border-l-[10px] -translate-y-[calc(50%+1px)] ${existingClasses}`
                  : `sd-arrow-head sd-arrow-left absolute left-0 top-1/2 w-0 h-0 border-t-[6px] border-t-transparent border-b-[6px] border-b-transparent border-r-[10px] -translate-y-[calc(50%+1px)] ${existingClasses}`;
            }
          }

          // Position label at midpoint between participants
          const label = message.querySelector(
            ".sd-message-label",
          ) as HTMLElement;
          if (label) {
            label.style.left = `${midpoint}%`;
            label.style.transform = "translateX(-50%)";
          }
        }
      });

      // Constrain label widths so they don't overflow the diagram,
      // then resize rows to fit any wrapped text.
      const diagramEl = diagram as HTMLElement;

      const constrainAndResize = () => {
        const diagramW = diagramEl.clientWidth;

        // Reset previous constraints
        diagram.querySelectorAll(".sd-label-text").forEach((label) => {
          (label as HTMLElement).style.maxWidth = "";
        });
        diagram.querySelectorAll(".sd-row").forEach((row) => {
          (row as HTMLElement).style.minHeight = "";
        });

        // Set max-width on message labels based on arrow span
        diagram.querySelectorAll(".sd-message").forEach((msg) => {
          const label = msg.querySelector(".sd-label-text") as HTMLElement;
          if (!label) return;

          const fromIdx = parseInt((msg as HTMLElement).getAttribute("data-from") || "0");
          const toIdx = parseInt((msg as HTMLElement).getAttribute("data-to") || "1");

          if (fromIdx === toIdx) {
            label.style.maxWidth = `${Math.max(80, diagramW * 0.4)}px`;
          } else {
            const fromP = participants[fromIdx] as HTMLElement | undefined;
            const toP = participants[toIdx] as HTMLElement | undefined;
            if (fromP && toP) {
              const span = Math.abs(
                parseFloat(fromP.getAttribute("data-position") || "0") -
                parseFloat(toP.getAttribute("data-position") || "0")
              );
              const maxPx = Math.max(80, (span / 100) * diagramW * 0.9);
              label.style.maxWidth = `${maxPx}px`;
            }
          }
        });

        // Set max-width on note labels
        diagram.querySelectorAll(".sd-row:not(.sd-message) .sd-label-text").forEach((label) => {
          (label as HTMLElement).style.maxWidth = `${Math.max(120, diagramW * 0.8)}px`;
        });

        // Resize rows to fit wrapped labels
        diagram.querySelectorAll(".sd-row").forEach((row) => {
          const el = row as HTMLElement;
          const labels = el.querySelectorAll(".sd-message-label, .sd-label-text");
          let maxH = 0;
          labels.forEach((lbl) => {
            const h = (lbl as HTMLElement).offsetHeight;
            if (h > maxH) maxH = h;
          });
          if (maxH > 0) {
            const needed = maxH + 32;
            if (needed > el.offsetHeight) {
              el.style.minHeight = `${needed}px`;
            }
          }
        });
      };

      constrainAndResize();
      window.addEventListener("resize", constrainAndResize);
    });
  });
</script>

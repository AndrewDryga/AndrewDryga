---
interface Props {
  label?: string;
  first?: boolean;
  class?: string;
}

const { label, first = false, class: className = "" } = Astro.props as Props;
---

<div
  class={[
    first ? "" : "pt-4 mt-4 border-t border-border/50",
    "space-y-6",
    className ?? "",
  ]
    .filter(Boolean)
    .join(" ")}
>
  {
    label ? (
      <div class="px-4 text-[10px] uppercase tracking-[0.2em] text-muted-foreground">
        {label}
      </div>
    ) : null
  }
  <div class="relative space-y-6">
    <slot />
  </div>
</div>

---
interface Props {
  participant?: number;
  class?: string;
}

const { participant = 0, class: className = "" } = Astro.props as Props;
---

<div
  class={`sd-activation-box relative ${className}`.trim()}
  data-participant={participant}
>
  <div class="sd-row absolute inset-0 pointer-events-none">
    <div
      class="sd-activation-bar absolute w-3 bg-primary/10 border border-primary top-2 bottom-2 -translate-x-1/2"
    >
    </div>
  </div>
  <div class="relative">
    <slot />
  </div>
</div>

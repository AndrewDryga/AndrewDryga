---
interface NavLink {
  label: string;
  href: string;
  active?: boolean;
}

interface Props {
  logo?: string;
  links?: NavLink[];
  class?: string;
}

const defaultLinks: NavLink[] = [
  { label: "Home", href: "#", active: true },
  { label: "About", href: "#" },
  { label: "Projects", href: "#" },
];

const {
  logo = "Logo",
  links = defaultLinks,
  class: className = "",
} = Astro.props as Props;
---

<div
  class={[
    "flex items-center justify-between rounded border border-border bg-terminal-surface p-4",
    className,
  ]
    .filter(Boolean)
    .join(" ")}
>
  <div class="font-mono text-terminal-cyan">{logo}</div>
  <button
    type="button"
    class="md:hidden flex flex-col gap-1.5 rounded-md border border-terminal-cyan/30 px-2 py-2 text-terminal-cyan transition-colors hover:bg-terminal-cyan/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-terminal-cyan/60"
    aria-label="Toggle navigation"
  >
    <span class="block h-0.5 w-6 bg-current"></span>
    <span class="block h-0.5 w-6 bg-current"></span>
    <span class="block h-0.5 w-6 bg-current"></span>
  </button>
  <nav class="hidden md:flex gap-4 font-mono text-sm">
    {
      links.map((link) => (
        <a
          href={link.href}
          class={`transition-colors ${
            link.active
              ? "text-terminal-cyan"
              : "text-foreground hover:text-terminal-cyan"
          }`}
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</div>

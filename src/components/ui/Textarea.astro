---
interface Props {
  class?: string;
  [key: string]: unknown;
}

const { class: className = "", ...rest } = Astro.props as Props;
---

<textarea
  class={[
    "w-full rounded-md border border-border bg-terminal-surface px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-terminal-cyan",
    className,
  ].filter(Boolean).join(" ")}
  {...rest}
></textarea>

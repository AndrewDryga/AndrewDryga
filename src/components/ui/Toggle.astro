---
interface Props {
  pressed?: boolean;
  class?: string;
  value?: string;
}

const {
  pressed = false,
  class: className = "",
  value,
  ...rest
} = Astro.props as Props & Record<string, unknown>;
---

<button
  type="button"
  role="switch"
  aria-checked={pressed}
  data-toggle={value ?? ""}
  class={[
    "inline-flex items-center rounded border px-3 py-1.5 font-mono text-xs transition-colors",
    pressed
      ? "border-terminal-cyan bg-terminal-cyan/10 text-terminal-cyan"
      : "border-border text-muted-foreground hover:border-terminal-cyan hover:text-terminal-cyan",
    className,
  ].filter(Boolean).join(" ")}
  {...rest}
>
  <slot />
</button>

<script is:inline>
  (() => {
    const btn = document.currentScript?.previousElementSibling;
    if (!(btn instanceof HTMLElement) || btn.getAttribute("role") !== "switch") return;
    btn.addEventListener("click", () => {
      const current = btn.getAttribute("aria-checked") === "true";
      const next = !current;
      btn.setAttribute("aria-checked", String(next));
      if (next) {
        btn.classList.remove("border-border", "text-muted-foreground");
        btn.classList.add("border-terminal-cyan", "bg-terminal-cyan/10", "text-terminal-cyan");
      } else {
        btn.classList.add("border-border", "text-muted-foreground");
        btn.classList.remove("border-terminal-cyan", "bg-terminal-cyan/10", "text-terminal-cyan");
      }
    });
  })();
</script>

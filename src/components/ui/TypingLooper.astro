---
interface Props {
  texts: string[];
  class?: string;
  pulseClass?: string;
}

const { texts, class: className = "inline-flex items-center gap-1", pulseClass = "animate-pulse" } =
  Astro.props as Props;

if (!Array.isArray(texts) || texts.length === 0) {
  throw new Error("TypingLooper requires a non-empty texts array");
}

const id = `typing-${crypto.randomUUID()}`;
const payload = JSON.stringify(texts);
---

<span id={id} class={className} data-texts={payload}>
  <span data-text></span>
  <span class={pulseClass} aria-hidden="true">▊</span>
</span>

<script is:inline data-typing-id={id}>
  (() => {
    const script = document.currentScript;
    const containerId = script?.dataset.typingId;
    if (!containerId) return;
    const container = document.getElementById(containerId);
    if (!container) return;
    const target = container.querySelector("[data-text]");
    if (!(target instanceof HTMLElement)) return;
    const raw = container.getAttribute("data-texts");
    if (!raw) return;
    let texts;
    try {
      texts = JSON.parse(raw);
    } catch {
      texts = [];
    }
    if (!Array.isArray(texts) || texts.length === 0) return;

    let index = 0;
    let deleting = false;
    let current = "";

    const tick = () => {
      const targetText = texts[index] ?? "";
      if (!deleting && current.length < targetText.length) {
        current = targetText.slice(0, current.length + 1);
      } else if (!deleting) {
        deleting = true;
        setTimeout(tick, 1400);
        return;
      } else if (deleting && current.length > 0) {
        current = targetText.slice(0, current.length - 1);
      } else {
        deleting = false;
        index = (index + 1) % texts.length;
      }

      target.textContent = current;
      const delay = deleting ? 60 : 90;
      setTimeout(tick, delay);
    };

    tick();
  })();
</script>

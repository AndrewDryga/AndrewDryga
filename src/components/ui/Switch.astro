---
interface Props {
  name?: string;
  checked?: boolean;
  defaultChecked?: boolean;
  class?: string;
  label?: string;
}

const {
  name,
  checked,
  defaultChecked,
  class: className = "",
  label,
  ...rest
} = Astro.props as Props & Record<string, unknown>;
---

<label class={['inline-flex items-center gap-3 cursor-pointer font-mono text-xs text-muted-foreground', className].filter(Boolean).join(' ')}>
  <span class="relative inline-flex h-5 w-9 items-center">
    <input
      type="checkbox"
      class="peer absolute inset-0 opacity-0 cursor-pointer"
      name={name}
      checked={defaultChecked !== undefined ? defaultChecked : checked}
      {...rest}
    />
    <span class="pointer-events-none absolute inset-0 rounded-full border border-border bg-terminal-surface transition-colors peer-checked:border-terminal-cyan peer-checked:bg-terminal-cyan/30 peer-focus-visible:ring-2 peer-focus-visible:ring-terminal-cyan"></span>
    <span class="pointer-events-none absolute left-1 h-3.5 w-3.5 rounded-full bg-muted-foreground transition-all duration-200 peer-checked:left-[1.125rem] peer-checked:bg-terminal-cyan"></span>
  </span>
  {label && <span>{label}</span>}
  {!label && <slot />}
</label>

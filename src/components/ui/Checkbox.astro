---
interface Props {
  checked?: boolean;
  defaultChecked?: boolean;
  disabled?: boolean;
  name?: string;
  value?: string;
  class?: string;
}

const {
  checked,
  defaultChecked,
  disabled = false,
  name,
  value,
  class: className = "",
  ...rest
} = Astro.props as Props & Record<string, unknown>;
---

<label
  class={[
    "inline-flex items-center gap-2 cursor-pointer select-none font-mono text-sm",
    disabled ? "opacity-60 cursor-not-allowed" : "",
    className,
  ]
    .filter(Boolean)
    .join(" ")}
>
  <input
    type="checkbox"
    class="sr-only peer"
    name={name}
    value={value}
    checked={checked}
    disabled={disabled}
    {...(defaultChecked !== undefined ? { checked: undefined, defaultChecked } : {})}
    {...rest}
  />
  <span
    class="h-4 w-4 rounded border border-border bg-terminal-surface ring-0 transition-colors peer-focus-visible:outline-none peer-focus-visible:ring-2 peer-focus-visible:ring-terminal-cyan peer-checked:border-terminal-cyan peer-checked:bg-terminal-cyan/80 peer-checked:text-background flex items-center justify-center"
  >
    <svg
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="3"
      fill="none"
      class="h-3 w-3 text-background opacity-0 transition-opacity peer-checked:opacity-100"
    >
      <polyline points="20 6 9 17 4 12" />
    </svg>
  </span>
  <span class="text-foreground">
    <slot />
  </span>
</label>

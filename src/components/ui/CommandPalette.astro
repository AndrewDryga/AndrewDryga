---
export interface CommandItem {
  label: string;
  shortcut?: string;
  href?: string;
  description?: string;
}

export interface CommandGroup {
  group: string;
  items: CommandItem[];
}

interface Props {
  /** Unique ID for this palette instance */
  id?: string;
  placeholder?: string;
  /** Flat list of items (ungrouped) */
  items?: CommandItem[];
  /** Grouped items — takes precedence over items if provided */
  groups?: CommandGroup[];
  /** CSS selector for external trigger buttons (default: [data-open-palette]) */
  triggerSelector?: string;
  /** Enable "/" hotkey to open (default: true) */
  slashKey?: boolean;
  /** Keyboard chord shortcuts: key is the second key after "g", value is href */
  chords?: Record<string, string>;
  class?: string;
}

const {
  id = "command-palette",
  placeholder = "Type a command...",
  items = [],
  groups,
  triggerSelector = "[data-open-palette]",
  slashKey = true,
  chords = {},
  class: className = "",
} = Astro.props;

// Normalize to groups
const resolvedGroups: CommandGroup[] = groups ?? (items.length > 0 ? [{ group: "", items }] : []);
const allItems = resolvedGroups.flatMap((g) => g.items);
const hasGroups = resolvedGroups.some((g) => g.group);
const dialogId = `${id}-dialog`;
---

<style>
  dialog.command-dialog {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: clamp(3rem, 6vw, 7rem) clamp(1.5rem, 4vw, 2.5rem);
    border: 0;
    background: transparent;
    color: inherit;
    width: 100vw;
    min-height: 100dvh;
    opacity: 0;
    transition: opacity 150ms ease-out;
    z-index: 100;
    box-sizing: border-box;
  }
  dialog.command-dialog:not([open]) { display: none; }
  dialog.command-dialog::backdrop {
    background: hsl(var(--terminal-bg) / 0.7);
    backdrop-filter: blur(12px);
  }
  dialog.command-dialog[data-open] { opacity: 1; }
  .command-dialog__panel {
    transform: translateY(-6px) scale(0.98);
    opacity: 0;
    transition: transform 150ms ease-out, opacity 150ms ease-out;
  }
  dialog.command-dialog[data-open] .command-dialog__panel {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
  @media (max-width: 640px) { dialog.command-dialog { padding: 1rem; } }
  [data-command-item][hidden] { display: none !important; }
  [data-command-group][hidden] { display: none !important; }
  [data-command-results] { scrollbar-width: thin; scrollbar-color: hsl(var(--border)) transparent; }
  [data-command-results]::-webkit-scrollbar { width: 6px; }
  [data-command-results]::-webkit-scrollbar-track { background: transparent; }
  [data-command-results]::-webkit-scrollbar-thumb { background: hsl(var(--border)); border-radius: 3px; }
  [data-command-results]::-webkit-scrollbar-thumb:hover { background: hsl(var(--terminal-cyan) / 0.4); }
</style>

<dialog id={dialogId} class:list={["command-dialog", className]} data-command-dialog>
  <div class="command-dialog__panel w-full max-w-xl overflow-hidden rounded-lg border border-border bg-terminal-bg shadow-[0_0_40px_rgba(34,211,238,0.2)] font-mono">
    <div class="flex items-center border-b border-border px-4">
      <svg class="mr-3 h-4 w-4 text-terminal-cyan shrink-0" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-3.5-3.5"></path>
      </svg>
      <input
        type="search"
        class="h-12 w-full bg-transparent text-sm text-foreground placeholder:text-muted-foreground focus:outline-none"
        placeholder={placeholder}
        data-command-input
      />
      <button type="button" class="ml-2 text-xs text-muted-foreground hover:text-terminal-cyan transition-colors shrink-0" data-command-close>ESC</button>
    </div>

    <div class="max-h-72 overflow-y-auto p-2" data-command-results>
      {resolvedGroups.map((g) => (
        <div data-command-group={g.group.toLowerCase()} class={hasGroups ? "mt-3 first:mt-0" : ""}>
          {g.group && (
            <div class="px-3 pt-2 pb-1 text-xs uppercase tracking-wider text-muted-foreground/80 font-semibold border-b border-border/30 mb-1">{g.group}</div>
          )}
          {g.items.map((item) => (
            <a
              href={item.href ?? "#"}
              class="group flex items-center justify-between rounded px-3 py-2 text-sm text-foreground transition-colors hover:bg-terminal-cyan/10"
              data-command-item
              data-search={[item.label, item.description || ""].join(" ").toLowerCase()}
            >
              <div class="min-w-0 flex-1">
                <div class="text-terminal-cyan group-hover:text-terminal-green truncate">{item.label}</div>
                {item.description && (
                  <div class="text-[11px] text-muted-foreground/60 truncate mt-0.5">{item.description}</div>
                )}
              </div>
              {item.shortcut && (
                <span class="ml-4 inline-flex items-center gap-1 text-[10px] text-muted-foreground/50 shrink-0">
                  {item.shortcut.split(" ").map((k) => (
                    <kbd class="px-1.5 py-0.5 rounded border border-border/60 bg-terminal-bg/80 uppercase leading-tight">{k}</kbd>
                  ))}
                </span>
              )}
            </a>
          ))}
        </div>
      ))}
      <div class="px-3 py-6 text-xs text-muted-foreground text-center hidden" data-command-empty>No results found.</div>
    </div>
  </div>
</dialog>

<script
  is:inline
  data-dialog-id={dialogId}
  data-trigger-selector={triggerSelector}
  data-slash-key={slashKey ? "true" : "false"}
  data-chords={JSON.stringify(chords)}
>
(function () {
  var script = document.currentScript;
  var dialogId = script.getAttribute("data-dialog-id");
  var triggerSelector = script.getAttribute("data-trigger-selector");
  var slashKey = script.getAttribute("data-slash-key") === "true";
  var chords = JSON.parse(script.getAttribute("data-chords") || "{}");

  var dialog = document.getElementById(dialogId);
  if (!dialog) return;
  var input = dialog.querySelector("[data-command-input]");
  var closeBtn = dialog.querySelector("[data-command-close]");
  var items = Array.from(dialog.querySelectorAll("[data-command-item]"));
  var groups = Array.from(dialog.querySelectorAll("[data-command-group]"));
  var emptyMsg = dialog.querySelector("[data-command-empty]");
  var activeIndex = -1;
  var gPending = false;

  function visibleItems() {
    return items.filter(function (el) { return !el.hasAttribute("hidden"); });
  }

  function setActive(idx) {
    var vis = visibleItems();
    if (!vis.length) { activeIndex = -1; return; }
    var clamped = ((idx % vis.length) + vis.length) % vis.length;
    vis.forEach(function (el, i) {
      if (i === clamped) {
        el.classList.add("bg-terminal-cyan/10");
        el.scrollIntoView({ block: "nearest" });
      } else {
        el.classList.remove("bg-terminal-cyan/10");
      }
    });
    activeIndex = clamped;
  }

  function clearActive() {
    items.forEach(function (el) { el.classList.remove("bg-terminal-cyan/10"); });
    activeIndex = -1;
  }

  function filter(q) {
    var query = q.trim().toLowerCase();
    var total = 0;
    var groupCounts = {};
    items.forEach(function (el) {
      var text = el.getAttribute("data-search") || "";
      var match = !query || text.includes(query);
      el.toggleAttribute("hidden", !match);
      if (match) {
        total++;
        var g = el.closest("[data-command-group]");
        if (g) groupCounts[g.getAttribute("data-command-group")] = true;
      }
    });
    groups.forEach(function (g) {
      g.toggleAttribute("hidden", !groupCounts[g.getAttribute("data-command-group")]);
    });
    if (emptyMsg) emptyMsg.classList.toggle("hidden", total > 0);
    if (total > 0) setActive(0); else clearActive();
  }

  function open() {
    if (dialog.hasAttribute("open")) return;
    dialog.showModal();
    dialog.setAttribute("data-open", "");
    input.value = "";
    filter("");
    input.focus();
  }

  function close() {
    if (!dialog.hasAttribute("open")) return;
    dialog.close();
    dialog.removeAttribute("data-open");
    clearActive();
  }

  // External triggers
  if (triggerSelector) {
    document.querySelectorAll(triggerSelector).forEach(function (btn) {
      btn.addEventListener("click", open);
    });
  }

  closeBtn.addEventListener("click", close);
  dialog.addEventListener("click", function (e) { if (e.target === dialog) close(); });
  dialog.addEventListener("cancel", function (e) { e.preventDefault(); close(); });

  input.addEventListener("input", function () { filter(input.value); });

  input.addEventListener("keydown", function (e) {
    var vis = visibleItems();
    if (e.key === "ArrowDown") { e.preventDefault(); setActive(activeIndex + 1); }
    else if (e.key === "ArrowUp") { e.preventDefault(); setActive(activeIndex - 1); }
    else if (e.key === "Enter" && vis.length) {
      e.preventDefault();
      var cur = vis[activeIndex >= 0 ? activeIndex : 0];
      if (cur) { cur.click(); close(); }
    }
  });

  items.forEach(function (el) {
    el.addEventListener("mouseenter", function () {
      var vis = visibleItems();
      var idx = vis.indexOf(el);
      if (idx !== -1) setActive(idx);
    });
    el.addEventListener("click", function () { close(); });
  });

  // Global keyboard shortcuts
  var hasChords = Object.keys(chords).length > 0;

  window.addEventListener("keydown", function (e) {
    var tag = document.activeElement && document.activeElement.tagName;
    var isInput = tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT";

    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      if (dialog.hasAttribute("open")) close(); else open();
      return;
    }

    if (slashKey && e.key === "/" && !isInput && !dialog.hasAttribute("open")) {
      e.preventDefault();
      open();
      return;
    }

    if (hasChords && !isInput && !dialog.hasAttribute("open") && !e.metaKey && !e.ctrlKey) {
      if (e.key === "g") {
        gPending = true;
        setTimeout(function () { gPending = false; }, 800);
        return;
      }
      if (gPending) {
        var target = chords[e.key.toLowerCase()];
        if (target) {
          e.preventDefault();
          gPending = false;
          window.location.href = target;
        }
      }
    }
  });
})();
</script>

---
interface ToastOptions {
  title?: string;
  description?: string;
  variant?: "default" | "success" | "warning" | "destructive";
  duration?: number;
}

interface Props {
  class?: string;
  position?: "top-right" | "top-left" | "bottom-right" | "bottom-left";
}

const { class: className = "", position = "top-right" } = Astro.props as Props;

const positionClass = {
  "top-right": "top-4 right-4",
  "top-left": "top-4 left-4",
  "bottom-right": "bottom-4 right-4",
  "bottom-left": "bottom-4 left-4",
}[position];
---

<div
  class={`pointer-events-none fixed z-[100] flex flex-col gap-3 ${positionClass} ${className}`.trim()}
  data-toaster
>
</div>

<script is:inline>
  (() => {
    const container = document.currentScript?.previousElementSibling;
    if (!(container instanceof HTMLElement)) return;

    const variantClasses = {
      default: "border-terminal-cyan/60 bg-terminal-bg text-terminal-cyan",
      success: "border-terminal-green/60 bg-terminal-bg text-terminal-green",
      warning: "border-terminal-yellow/60 bg-terminal-bg text-terminal-yellow",
      destructive: "border-destructive/60 bg-terminal-bg text-destructive",
    };

    window.addEventListener("toast", (event) => {
      const detail = event.detail || {};
      const variant = variantClasses[detail.variant] ?? variantClasses.default;
      const duration = detail.duration ?? 4000;

      const toast = document.createElement("div");
      toast.className = `pointer-events-auto min-w-[240px] rounded-md border px-4 py-3 font-mono text-sm shadow-[0_10px_30px_rgba(34,211,238,0.25)] transition-all duration-200 ease-out ${variant}`;
      toast.innerHTML = `
        ${detail.title ? `<p class="font-semibold">${detail.title}</p>` : ""}
        ${detail.description ? `<p class="text-xs text-muted-foreground/80 mt-1">${detail.description}</p>` : ""}
      `;
      toast.classList.add("opacity-0", "translate-y-2");
      container.appendChild(toast);
      requestAnimationFrame(() => {
        toast.classList.remove("opacity-0", "translate-y-2");
      });

      setTimeout(() => {
        toast.classList.add("opacity-0", "translate-y-2");
        toast.addEventListener("transitionend", () => toast.remove(), {
          once: true,
        });
      }, duration);
    });
  })();
</script>

---
interface Props {
  src?: string;
  alt?: string;
  initials?: string;
  size?: "sm" | "md" | "lg";
  class?: string;
}

const {
  src,
  alt = "",
  initials,
  size = "md",
  class: className = "",
  ...rest
} = Astro.props as Props & Record<string, unknown>;

const sizeClasses: Record<NonNullable<Props["size"]>, string> = {
  sm: "h-8 w-8 text-xs",
  md: "h-12 w-12 text-sm",
  lg: "h-16 w-16 text-base",
};
---

<div
  class={[
    "relative inline-flex overflow-hidden rounded-full border border-border bg-terminal-surface text-terminal-cyan items-center justify-center font-mono uppercase",
    sizeClasses[size],
    className,
  ]
    .filter(Boolean)
    .join(" ")}
  {...rest}
>
  {src ? (
    <img
      class="h-full w-full object-cover"
      src={src}
      alt={alt}
      loading="lazy"
      onerror="this.remove();"
    />
  ) : initials ? (
    initials
  ) : (
    <span class="opacity-60">?</span>
  )}
</div>

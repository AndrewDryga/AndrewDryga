---
interface Props {
  length?: number;
  name?: string;
  class?: string;
}

const {
  length = 6,
  name = "otp",
  class: className = "",
} = Astro.props as Props;

const boxes = Array.from({ length });
---

<div
  class={[
    "flex gap-2",
    className,
  ].filter(Boolean).join(" ")}
  data-otp
>
  {boxes.map((_, index) => (
    <input
      type="text"
      inputmode="numeric"
      maxlength="1"
      class="h-10 w-10 rounded-md border border-border bg-terminal-surface text-center text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-terminal-cyan"
      name={`${name}-${index}`}
      data-otp-input
    />
  ))}
</div>

<script is:inline>
  (() => {
    const container = document.currentScript?.previousElementSibling;
    if (!container) return;
    const inputs = Array.from(container.querySelectorAll('[data-otp-input]'));
    inputs.forEach((input, idx) => {
      input.addEventListener('input', (event) => {
        const value = event.target.value.replace(/[^0-9a-zA-Z]/g, '').slice(0, 1);
        event.target.value = value;
        if (value && inputs[idx + 1]) {
          inputs[idx + 1].focus();
        }
      });
      input.addEventListener('keydown', (event) => {
        if (event.key === 'Backspace' && !event.target.value && inputs[idx - 1]) {
          inputs[idx - 1].focus();
        }
      });
    });
  })();
</script>

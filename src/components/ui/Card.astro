---
interface Props {
  class?: string;
}

const { class: className = "", ...rest } = Astro.props as Props & Record<string, unknown>;

const classes = [
  "rounded-lg border border-border bg-card text-card-foreground shadow-sm",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<div class={classes} {...rest}>
  <slot />
</div>

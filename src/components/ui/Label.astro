---
interface Props {
  class?: string;
  [key: string]: unknown;
}

const { class: className = "", ...rest } = Astro.props as Props;
---

<label
  class={[
    "font-mono text-xs uppercase tracking-wide text-muted-foreground",
    className,
  ].filter(Boolean).join(" ")}
  {...rest}
>
  <slot />
</label>

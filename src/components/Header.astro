---
import MobileNav from "./MobileNav.astro";

export interface Props {
  /**
   * Which part to render:
   * - 'header' (default): renders the top navigation bar
   * - 'footer': renders the site footer
   * - 'both': renders header then footer
   */
  variant?: "header" | "footer" | "both";
}

const { variant = "header" } = Astro.props;

const pathname = Astro.url.pathname ?? "/";
const year = new Date().getFullYear();

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  if (href.startsWith("/blog")) return pathname.startsWith("/blog");
  if (href.startsWith("/projects")) return pathname.startsWith("/projects");
  if (href.startsWith("/#")) {
    // Hash links are activated via client-side scrollspy on the home page
    return false;
  }
  return pathname === href;
}

const navLinks = [
  { name: "Home", href: "/" },
  { name: "About", href: "/#about" },
  { name: "Projects", href: "/projects" },
  { name: "Blog", href: "/blog" },
  { name: "Contact", href: "/#contact" },
];
---

{(variant === "header" || variant === "both") && (
  <header data-nav-behavior="primary" class="sticky top-0 z-50 backdrop-blur-lg bg-background/80 border-b border-border">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex justify-between items-center h-16">
        {/* Logo */}
        <a
          href="/"
          class="font-mono text-lg text-terminal-cyan hover:text-terminal-green transition-colors"
          aria-label="Go to home"
        >
          &gt; andrew_dryga
        </a>

        {/* Desktop Navigation */}
        <nav class="hidden md:flex items-center gap-8" aria-label="Primary">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class={[
                "font-mono text-sm transition-colors",
                isActive(link.href)
                  ? "text-terminal-cyan"
                  : "text-muted-foreground hover:text-terminal-green",
              ].join(" ")}
            >
              {link.name}
            </a>
          ))}
        </nav>

        {/* Mobile Navigation */}
        <MobileNav class="md:hidden" links={navLinks} />
      </div>
    </div>
  </header>
  <script>
    import "../scripts/header-nav.ts";
  </script>
)}

{(variant === "footer" || variant === "both") && (
  <footer class="py-4 md:py-8 px-4 border-t border-border">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="font-mono text-sm text-muted-foreground"><span class="relative top-[1.5px] pr-2">©</span> {year} Andrii Dryga</p>
        <p class="font-mono text-sm text-terminal-cyan">&gt; Powered by code and curiosity</p>
      </div>
    </div>
  </footer>
)}

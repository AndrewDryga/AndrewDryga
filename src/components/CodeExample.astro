---
interface Props {
  code: string;
  label?: string;
  language?: string;
  class?: string;
}

const {
  code,
  label,
  language = "tsx",
  class: className = "",
} = Astro.props as Props;

const exampleId = `code-example-${crypto.randomUUID()}`;
const displayLabel = label ?? language.toUpperCase();
---

<div
  class={`relative rounded-lg border border-terminal-cyan/35 bg-terminal-surface/80 p-4 ${className}`.trim()}
  data-code-example
>
  {displayLabel ? (
    <span class="mb-3 inline-flex rounded-full border border-terminal-cyan/40 px-3 py-1 text-[10px] font-mono uppercase tracking-[0.2em] text-terminal-cyan/80">
      {displayLabel}
    </span>
  ) : null}
  <button
    type="button"
    aria-label="Copy code snippet"
    class="absolute right-4 top-4 text-[11px] font-mono uppercase tracking-[0.2em] text-muted-foreground transition-colors hover:text-terminal-cyan"
    data-copy-button
    data-copy-target={exampleId}
  >
    Copy
  </button>
  <pre class="m-0 overflow-x-auto font-mono text-sm leading-relaxed text-foreground">
    <code id={exampleId}>{code}</code>
  </pre>
</div>

<script is:inline>
  (() => {
    const root = document.currentScript?.parentElement;
    if (!root) return;

    const button = root.querySelector("[data-copy-button]");
    if (!button) return;

    const targetId = button.getAttribute("data-copy-target");
    if (!targetId) return;

    button.addEventListener("click", async () => {
      const codeElement = document.getElementById(targetId);
      if (!codeElement) return;

      const text = codeElement.textContent ?? "";
      try {
        await navigator.clipboard.writeText(text);
        const original = button.textContent;
        button.textContent = "Copied";
        setTimeout(() => {
          if (original) button.textContent = original;
        }, 1500);
      } catch (error) {
        console.error("Failed to copy code sample", error);
      }
    });
  })();
</script>

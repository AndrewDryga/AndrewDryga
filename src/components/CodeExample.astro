---
interface Props {
  code: string;
  label?: string;
  language?: string;
  class?: string;
}

const {
  code,
  label,
  language = "tsx",
  class: className = "",
} = Astro.props as Props;

const exampleId = `code-example-${crypto.randomUUID()}`;
---

<div
  class={`relative border border-border rounded-lg overflow-hidden bg-terminal-surface ${className}`.trim()}
  data-code-example
>
  <div class="flex items-center justify-between px-4 py-2 border-b border-border bg-card">
    <span class="text-xs font-mono text-muted-foreground">
      {label ?? language.toUpperCase()}
    </span>
    <button
      type="button"
      class="text-xs font-mono text-primary hover:text-primary/80 transition-colors"
      data-copy-button
      data-copy-target={exampleId}
    >
      Copy
    </button>
  </div>
  <pre class="p-4 overflow-x-auto text-sm font-mono leading-relaxed">
    <code id={exampleId}>{code}</code>
  </pre>
</div>

<script is:inline>
  (() => {
    const root = document.currentScript?.parentElement;
    if (!root) return;

    const button = root.querySelector("[data-copy-button]");
    if (!button) return;

    const targetId = button.getAttribute("data-copy-target");
    if (!targetId) return;

    button.addEventListener("click", async () => {
      const codeElement = document.getElementById(targetId);
      if (!codeElement) return;

      const text = codeElement.textContent ?? "";
      try {
        await navigator.clipboard.writeText(text);
        const original = button.textContent;
        button.textContent = "Copied";
        setTimeout(() => {
          if (original) button.textContent = original;
        }, 1500);
      } catch (error) {
        console.error("Failed to copy code sample", error);
      }
    });
  })();
</script>

---
---
<form class="space-y-4 rounded-lg border border-border bg-background/60 p-5">
  <div class="space-y-2">
    <label class="block font-mono text-xs uppercase tracking-wide text-muted-foreground" for="env-name">
      Environment name
    </label>
    <input
      id="env-name"
      type="text"
      value="staging"
      class="w-full rounded border border-border bg-background px-3 py-2 font-mono text-sm text-foreground focus:border-terminal-cyan focus:outline-none focus:ring-2 focus:ring-terminal-cyan"
    />
    <p class="text-xs text-muted-foreground">
      Slugged automatically and used in deployment URLs.
    </p>
  </div>

  <div class="space-y-2">
    <label class="block font-mono text-xs uppercase tracking-wide text-muted-foreground" for="region">
      Region
    </label>
    <select
      id="region"
      class="w-full rounded border border-border bg-background px-3 py-2 font-mono text-sm text-foreground focus:border-terminal-cyan focus:outline-none focus:ring-2 focus:ring-terminal-cyan"
    >
      <option>us-east-1</option>
      <option>us-west-2</option>
      <option>eu-central-1</option>
    </select>
  </div>

  <div class="flex justify-end gap-2">
    <button type="button" class="rounded-md border border-border px-3 py-2 font-mono text-xs text-muted-foreground hover:border-terminal-cyan/60 hover:text-terminal-cyan">
      Cancel
    </button>
    <button type="submit" class="inline-flex items-center gap-2 rounded-md border border-terminal-cyan px-3 py-2 font-mono text-xs text-terminal-cyan transition-colors hover:bg-terminal-cyan hover:text-background">
      Save environment
    </button>
  </div>
</form>

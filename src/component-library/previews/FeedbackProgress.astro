---
const { value = 67 } = Astro.props;
---

<div class="rounded-lg border border-border bg-background/60 p-6">
  <div class="flex items-center justify-between font-mono text-xs text-muted-foreground">
    <span>Status: Uploading logs</span>
    <span>{value}%</span>
  </div>
  <div class="mt-3 h-3 rounded-full bg-terminal-cyan/10">
    <div class="h-full rounded-full bg-terminal-cyan" style={`width: ${Math.min(Math.max(value, 0), 100)}%`}></div>
  </div>
  <p class="mt-2 text-xs text-muted-foreground">
    This stripe animation uses pure CSS, respects reduced motion, and exposes status via aria-live when wired up.
  </p>
</div>

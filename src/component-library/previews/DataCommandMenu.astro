---
<div class="rounded-lg border border-border bg-background/60 p-5">
  <div class="flex items-center gap-2 rounded-md border border-border bg-card px-3 py-2">
    <svg class="h-4 w-4 text-muted-foreground" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.35-4.35"></path>
    </svg>
    <input
      type="search"
      placeholder="Search commands..."
      class="w-full bg-transparent text-sm text-foreground placeholder:text-muted-foreground focus:outline-none"
    />
    <kbd class="rounded bg-terminal-cyan/10 px-2 py-1 text-[10px] font-mono text-terminal-cyan">⌘K</kbd>
  </div>
  <div class="mt-4 space-y-2">
    <p class="text-[11px] font-mono uppercase tracking-wide text-muted-foreground">Common actions</p>
    <ul class="space-y-1 rounded-md border border-border/60 bg-card/50 p-2 text-sm">
      <li class="rounded px-2 py-1 text-foreground hover:bg-terminal-cyan/10">Create deployment</li>
      <li class="rounded px-2 py-1 text-foreground hover:bg-terminal-cyan/10">View incidents</li>
      <li class="rounded px-2 py-1 text-foreground hover:bg-terminal-cyan/10">Open documentation</li>
    </ul>
  </div>
</div>
